<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:Class="PsychologyApp.Presentation.Controls.TechniquePageShell"
             x:Name="Root">

    <ScrollView VerticalScrollBarVisibility="Never">
        <StackLayout Margin="20,0,20,20" Spacing="20">
            <ui:NavigationBarExtendedView
                TitleText="{Binding Source={x:Reference Root}, Path=TitleText}"
                BackCommand="{Binding Source={x:Reference Root}, Path=BackCommand}"
                ExtensionText="{Binding Source={x:Reference Root}, Path=TheoryText}"
                ExtensionCommand="{Binding Source={x:Reference Root}, Path=TheoryCommand}" />
            <ui:AlgorithmBoxView
                TitleText="{Binding Source={x:Reference Root}, Path=AlgorithmTitleText}"
                BodySource="{Binding Source={x:Reference Root}, Path=Algorithm}" />
            <ContentPresenter Content="{Binding Source={x:Reference Root}, Path=BodyContent}" />
            <ui:ButtonView
                BodyText="{Binding Source={x:Reference Root}, Path=FinishText}"
                TapCommand="{Binding Source={x:Reference Root}, Path=FinishCommand}" />
        </StackLayout>
    </ScrollView>
</ContentView>
