<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.RunTechniqueSession.TechniqueSession.TechniqueSessionPage"
             xmlns:controls="clr-namespace:PsychologyApp.Presentation.Widgets.TechniqueSessionShell"
             xmlns:shellBehaviors="clr-namespace:PsychologyApp.Presentation.Widgets.TechniqueSessionShell"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             Shell.NavBarIsVisible="False"
             Title="{Binding TechniquePageTitle}">

    <ContentPage.Behaviors>
        <shellBehaviors:TechniqueSessionBehavior />
    </ContentPage.Behaviors>

    <controls:TechniquePageShell
        x:Name="SessionShell"
        TitleText="{Binding PageName}"
        Algorithm="{Binding Algorithm}"
        BackCommand="{Binding BackCommand}"
        TheoryCommand="{Binding Theory}"
        FinishCommand="{Binding CompleteCommand}">
        <controls:TechniquePageShell.Behaviors>
            <behaviors:RevealOnAppearingBehavior />
        </controls:TechniquePageShell.Behaviors>
    </controls:TechniquePageShell>
</ContentPage>
