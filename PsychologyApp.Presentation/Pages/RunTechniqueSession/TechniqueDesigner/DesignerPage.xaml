<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.RunTechniqueSession.TechniqueDesigner.DesignerPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Pages.RunTechniqueSession.TechniqueDesigner"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:DataType="vm:DesignerViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <ScrollView
        VerticalOptions="FillAndExpand"
        VerticalScrollBarVisibility="Never"
        HorizontalScrollBarVisibility="Never">
        <VerticalStackLayout Margin="{StaticResource LayoutPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">
            <VerticalStackLayout.Behaviors>
                <behaviors:StaggerChildrenBehavior />
            </VerticalStackLayout.Behaviors>

            <ui:NavigationBarSimpleView
                TitleText="{Binding DesignTitle}"
                BackText="{Binding BackText}"
                BackCommand="{Binding Finish}" />

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding DescriptionSection}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:TextEntryView
                        TitleText="{Binding NameFieldLabel}"
                        PlaceholderText="{Binding NamePlaceholder}"
                        BodyText="{Binding Name}" />
                    <ui:TextEntryView
                        TitleText="{Binding DescriptionFieldLabel}"
                        PlaceholderText="{Binding DescriptionPlaceholder}"
                        BodyText="{Binding Description}" />
                    <ui:TextEntryView
                        TitleText="{Binding ThemeFieldLabel}"
                        PlaceholderText="{Binding ThemePlaceholder}"
                        BodyText="{Binding Theme}" />
                    <ui:TextEntryView
                        TitleText="{Binding AuthorFieldLabel}"
                        PlaceholderText="{Binding AuthorPlaceholder}"
                        BodyText="{Binding Author}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding AlgorithmSection}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:TextEntryView
                        TitleText="{Binding ActionsFieldLabel}"
                        BodyText="{Binding Actions}" />
                </VerticalStackLayout>
            </Border>

            <ui:ButtonView
                BodyText="{Binding SaveButtonText}"
                TapCommand="{Binding ExecuteTechnique}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
