<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.Onboarding.OnboardingPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Pages.Onboarding"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             x:DataType="vm:OnboardingViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource LayoutTabPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">
            <VerticalStackLayout x:Name="WelcomeStep" IsVisible="{Binding IsWelcomeStep}" Spacing="12">
                <Label Text="{Binding WelcomeTitle}" Style="{StaticResource PageTitleStyle}" />
                <Label Text="{Binding WelcomeBody}" Style="{StaticResource BodyStyle}" />
                <ui:ButtonView BodyText="{Binding NextLabel}" TapCommand="{Binding NextCommand}" />
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="ConcernStep" IsVisible="{Binding IsConcernStep}" Spacing="12">
                <Label Text="{Binding ConcernTitle}" Style="{StaticResource PageTitleStyle}" />
                <ui:ButtonView Variant="{Binding ConcernAnxietyVariant}" BodyText="{Binding ConcernAnxiety}" TapCommand="{Binding SelectAnxietyCommand}" />
                <ui:ButtonView Variant="{Binding ConcernBodyVariant}" BodyText="{Binding ConcernBody}" TapCommand="{Binding SelectBodyCommand}" />
                <ui:ButtonView Variant="{Binding ConcernMoodVariant}" BodyText="{Binding ConcernMood}" TapCommand="{Binding SelectMoodCommand}" />
                <ui:ButtonView Variant="{Binding ConcernExploreVariant}" BodyText="{Binding ConcernExplore}" TapCommand="{Binding SelectExploreCommand}" />
                <ui:ButtonView BodyText="{Binding NextLabel}" TapCommand="{Binding NextCommand}" />
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="DisclaimerStep" IsVisible="{Binding IsDisclaimerStep}" Spacing="12">
                <Label Text="{Binding DisclaimerTitle}" Style="{StaticResource PageTitleStyle}" />
                <Label Text="{Binding DisclaimerBody}" Style="{StaticResource BodyStyle}" />
                <ui:ButtonView BodyText="{Binding StartLabel}" TapCommand="{Binding StartPracticeCommand}" />
                <ui:ButtonView Variant="Secondary" BodyText="{Binding SkipLabel}" TapCommand="{Binding SkipCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
