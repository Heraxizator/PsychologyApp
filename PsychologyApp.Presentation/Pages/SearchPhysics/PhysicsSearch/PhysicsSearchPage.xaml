<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.SearchPhysics.PhysicsSearch.PhysicsSearchPage"
             x:Name="PageRoot"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Pages.SearchPhysics.PhysicsSearch"
             xmlns:physics="clr-namespace:PsychologyApp.Presentation.Entities.Physics"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:physicsUi="clr-namespace:PsychologyApp.Presentation.Widgets.PhysicsReasonCard"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:DataType="vm:PhysicsSearchViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <Grid
        HorizontalOptions="FillAndExpand"
        VerticalOptions="FillAndExpand">

        <Grid
            IsVisible="{Binding IsDone}"
            Margin="{StaticResource LayoutPageMarginThickness}"
            RowDefinitions="Auto,Auto,*">

            <ui:NavigationBarSimpleView
                Grid.Row="0"
                TitleText="{Binding PageTitle}"
                BackCommand="{Binding Finish}"/>

            <ui:TextEntryView
                Grid.Row="1"
                Margin="{StaticResource FieldVerticalMargin}"
                PlaceholderText="{Binding IllnessPlaceholder}"
                BodyText="{Binding SearchText, Mode=TwoWay}"
                TitleText="{Binding ProblemLabel}"/>

            <Grid Grid.Row="2">
                <ui:EmptyStateView
                    x:Name="SearchEmptyPrompt"
                    IsVisible="{Binding IsSearchEmptyPromptVisible}"
                    TitleText="{Binding EmptySearchHint}"
                    BodyText="{Binding EmptySearchSubhint}" />

                <ui:ProgressBarView
                    x:Name="SearchFilteringProgress"
                    IsVisible="{Binding IsSearchFilteringVisible}"
                    IsLoading="{Binding IsSearchFilteringVisible}"
                    ProgressText="{Binding SearchFilteringText}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center" />

                <ui:EmptyStateView
                    x:Name="SearchNoResults"
                    IsVisible="{Binding IsSearchNoResultsVisible}"
                    TitleText="{Binding NoResultsHint}"
                    BodyText="{Binding NoResultsSubhint}"
                    IconName="SearchOff" />

                <CollectionView
                    x:Name="SearchResultsCollectionView"
                    IsVisible="{Binding IsSearchResultsListVisible}"
                    SelectionMode="None"
                    VerticalOptions="FillAndExpand"
                    HorizontalOptions="FillAndExpand"
                    VerticalScrollBarVisibility="Never"
                    RemainingItemsThreshold="5"
                    RemainingItemsThresholdReached="OnRemainingItemsThresholdReached"
                    ItemsSource="{Binding ResultsObservableCollection}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="{StaticResource ListItemSpacing}" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="physics:PhysicsReasonItem">
                            <physicsUi:PhysicsReasonCardView
                                TitleFormatted="{Binding HighlightedTitle}"
                                SubtitleFormatted="{Binding HighlightedSubtitle}"
                                Solution="{Binding Solution}"
                                IsExpanded="{Binding IsExpanded}"
                                ToggleExpandCommand="{Binding ToggleExpandCommand}"
                                SuggestedTechniques="{Binding SuggestedTechniques}"
                                SolutionHeader="{Binding SolutionHeader, Source={x:Reference PageRoot}, Path=BindingContext}"
                                RecommendedPracticesLabel="{Binding RecommendedPracticesLabel, Source={x:Reference PageRoot}, Path=BindingContext}">
                                <physicsUi:PhysicsReasonCardView.Behaviors>
                                    <behaviors:ListItemRevealBehavior />
                                </physicsUi:PhysicsReasonCardView.Behaviors>
                            </physicsUi:PhysicsReasonCardView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>

        <ui:ProgressBarView
            x:Name="InitLoadingProgress"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsLoadingOverlayVisible}"
            IsLoading="{Binding IsLoadingOverlayVisible}"
            ProgressText="{Binding LoadingText}">
            <ui:ProgressBarView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Cancel}"/>
            </ui:ProgressBarView.GestureRecognizers>
        </ui:ProgressBarView>

        <ui:RetryView
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding FailedText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding Reload}" />
    </Grid>
</ContentPage>
