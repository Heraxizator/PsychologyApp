<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.PracticeCompletion.PracticeCompletionPage"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Pages.PracticeCompletion"
             x:DataType="vm:PracticeCompletionViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource Gray950}}">

    <ui:CompletionCelebrationView
        TitleText="{Binding TitleText}"
        BodyText="{Binding BodyText}"
        StreakValueText="{Binding StreakValueText}"
        StreakLabelText="{Binding StreakLabelText}"
        HasStreak="{Binding HasStreak}"
        PrimaryActionText="{Binding MorePracticeText}"
        PrimaryCommand="{Binding MorePracticeCommand}"
        SecondaryActionText="{Binding GoHomeText}"
        SecondaryCommand="{Binding GoHomeCommand}" />

</ContentPage>
