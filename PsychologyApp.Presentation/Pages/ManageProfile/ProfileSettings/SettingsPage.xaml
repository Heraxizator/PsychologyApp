<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Pages.ManageProfile.ProfileSettings.SettingsPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Pages.ManageProfile.ProfileSettings"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:converters="clr-namespace:PsychologyApp.Presentation.Shared.UI.Converters"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:DataType="vm:SettingsViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <ScrollView HorizontalScrollBarVisibility="Never" VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Margin="{StaticResource LayoutPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">
            <VerticalStackLayout.Behaviors>
                <behaviors:StaggerChildrenBehavior />
            </VerticalStackLayout.Behaviors>

            <ui:NavigationBarSimpleView
                TitleText="{Binding PageTitle}"
                BackCommand="{Binding Finish}" />

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding DesignSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.Language}"
                        LabelText="{Binding LanguageLabel}"
                        PickerTitle="{Binding LanguagePickerTitle}"
                        ItemsSource="{Binding LanguageOptions}"
                        SelectedItem="{Binding Language}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.Theme}"
                        LabelText="{Binding ThemeLabel}"
                        PickerTitle="{Binding ThemePickerTitle}"
                        ItemsSource="{Binding ThemeOptions}"
                        SelectedItem="{Binding Theme}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.Color}"
                        LabelText="{Binding ColorLabel}"
                        PickerTitle="{Binding ColorPickerTitle}"
                        ItemsSource="{Binding ColorOptions}"
                        SelectedItem="{Binding Color}" />
                    <Label Text="{Binding ColorHelperText}" Style="{StaticResource CaptionStyle}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.Form}"
                        LabelText="{Binding FormLabel}"
                        PickerTitle="{Binding FormPickerTitle}"
                        ItemsSource="{Binding FormOptions}"
                        SelectedItem="{Binding Form}" />
                    <Label Text="{Binding FormHelperText}" Style="{StaticResource CaptionStyle}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding FontSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.Size}"
                        LabelText="{Binding SizeLabel}"
                        PickerTitle="{Binding SizePickerTitle}"
                        ItemsSource="{Binding SizeOptions}"
                        SelectedItem="{Binding Size}" />
                    <ui:SettingSwitchRowView
                        LabelText="{Binding BoldLabel}"
                        IsToggled="{Binding IsThick}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding PracticeSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:SettingSwitchRowView
                        LabelText="{Binding PracticeRemindersLabel}"
                        IsToggled="{Binding PracticeRemindersEnabled}" />
                    <ui:SettingPickerRowView
                        LabelKind="{x:Static converters:PreferenceLabelKind.PassThrough}"
                        LabelText="{Binding PracticeReminderHourLabel}"
                        PickerTitle="{Binding PracticeReminderHourPickerTitle}"
                        ItemsSource="{Binding PracticeReminderHourOptions}"
                        SelectedItem="{Binding PracticeReminderHour}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                <VerticalStackLayout Spacing="{StaticResource CompactSpacing}">
                    <Label Text="{Binding TestsSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <ui:SettingSwitchRowView
                        LabelText="{Binding QuestionnaireAutoAdvanceLabel}"
                        IsToggled="{Binding QuestionnaireAutoAdvance}" />
                </VerticalStackLayout>
            </Border>

            <ui:ButtonView
                BodyText="{Binding ApplyButtonText}"
                TapCommand="{Binding ApplyCommand}" />

            <ui:ButtonView
                Variant="Secondary"
                BodyText="{Binding ReplayOnboardingText}"
                TapCommand="{Binding ReplayOnboardingCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
