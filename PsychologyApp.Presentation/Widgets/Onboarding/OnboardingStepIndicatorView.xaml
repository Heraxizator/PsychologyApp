<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Widgets.Onboarding.OnboardingStepIndicatorView"
             x:Name="Root">

    <VerticalStackLayout Spacing="8">
        <Label
            x:Name="StepLabelView"
            Text="{Binding StepLabel, Source={x:Reference Root}}"
            IsVisible="{Binding ShowStepLabel, Source={x:Reference Root}}"
            Style="{StaticResource CaptionStyle}"
            HorizontalTextAlignment="Center"
            TextColor="{DynamicResource Primary}" />
        <HorizontalStackLayout
            x:Name="DotsLayout"
            Spacing="8"
            HorizontalOptions="Center" />
    </VerticalStackLayout>

</ContentView>
