<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             x:Class="PsychologyApp.Presentation.Widgets.Onboarding.OnboardingValueStripView"
             x:Name="Root">

    <Border Style="{StaticResource MoodStripStyle}">
        <FlexLayout
            Wrap="Wrap"
            JustifyContent="Center"
            AlignItems="Center"
            Direction="Row">
            <Border
                Margin="0,0,8,8"
                Padding="10,6"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <ui:MaterialIconView
                        IconName="CloudOff"
                        IconColor="{DynamicResource Primary}"
                        IconSize="18"
                        WidthRequest="20"
                        HeightRequest="20"
                        VerticalOptions="Center" />
                    <Label
                        Text="{Binding Source={x:Reference Root}, Path=OfflineText}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
            <Border
                Margin="0,0,8,8"
                Padding="10,6"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <ui:MaterialIconView
                        IconName="FavoriteBorder"
                        IconColor="{DynamicResource Primary}"
                        IconSize="18"
                        WidthRequest="20"
                        HeightRequest="20"
                        VerticalOptions="Center" />
                    <Label
                        Text="{Binding Source={x:Reference Root}, Path=NoJudgmentText}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
            <Border
                Margin="0,0,0,0"
                Padding="10,6"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="6">
                    <ui:MaterialIconView
                        IconName="Smartphone"
                        IconColor="{DynamicResource Primary}"
                        IconSize="18"
                        WidthRequest="20"
                        HeightRequest="20"
                        VerticalOptions="Center" />
                    <Label
                        Text="{Binding Source={x:Reference Root}, Path=OnDeviceText}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </FlexLayout>
    </Border>

</ContentView>
