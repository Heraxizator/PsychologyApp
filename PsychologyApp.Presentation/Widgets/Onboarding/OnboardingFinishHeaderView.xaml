<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             x:Class="PsychologyApp.Presentation.Widgets.Onboarding.OnboardingFinishHeaderView"
             x:Name="Root">

    <Border
        x:Name="CheckCircleBorder"
        WidthRequest="56"
        HeightRequest="56"
        StrokeThickness="0"
        BackgroundColor="{AppThemeBinding Light={DynamicResource PrimaryTint}, Dark={DynamicResource PrimaryTintDark}}"
        HorizontalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="28" />
        </Border.StrokeShape>
        <ui:MaterialIconView
            IconName="CheckCircle"
            IconColor="{DynamicResource Primary}"
            WidthRequest="32"
            HeightRequest="32"
            HorizontalOptions="Center"
            VerticalOptions="Center" />
    </Border>

</ContentView>
