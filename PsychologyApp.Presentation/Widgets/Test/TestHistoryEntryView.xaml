<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:testUi="clr-namespace:PsychologyApp.Presentation.Widgets.Test"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:Class="PsychologyApp.Presentation.Widgets.Test.TestHistoryEntryView"
             x:Name="Root">

    <ContentView.Behaviors>
        <behaviors:ListItemRevealBehavior />
    </ContentView.Behaviors>

    <Border Style="{StaticResource ListEntryCardStyle}">
        <VerticalStackLayout Spacing="6">
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    Grid.Column="0"
                    Text="{Binding DateText, Source={x:Reference Root}}"
                    Style="{StaticResource CaptionStyle}" />
                <Border
                    Grid.Column="1"
                    IsVisible="{Binding HasTrend, Source={x:Reference Root}}"
                    Padding="8,2"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={DynamicResource PrimaryTint}, Dark={DynamicResource PrimaryTintDark}}">
                    <Border.Triggers>
                        <DataTrigger
                            Binding="{Binding IsWorse, Source={x:Reference Root}}"
                            TargetType="Border"
                            Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Label
                        Text="{Binding TrendText, Source={x:Reference Root}}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}"
                        FontFamily="{StaticResource SemiBoldFontFamily}">
                        <Label.Triggers>
                            <DataTrigger
                                Binding="{Binding IsWorse, Source={x:Reference Root}}"
                                TargetType="Label"
                                Value="True">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </Grid>
            <Label
                IsVisible="{Binding HasScore, Source={x:Reference Root}}"
                Text="{Binding ScoreText, Source={x:Reference Root}}"
                Style="{StaticResource CaptionStyle}"
                FontFamily="{StaticResource MediumFontFamily}"
                TextColor="{DynamicResource Primary}" />
            <Label Text="{Binding SummaryText, Source={x:Reference Root}}" Style="{StaticResource BodyStyle}" />
            <Expander IsVisible="{Binding HasDetail, Source={x:Reference Root}}">
                <Expander.Header>
                    <Label
                        Text="{Binding DurationText, Source={x:Reference Root}}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}" />
                </Expander.Header>
                <testUi:QuestionnaireResultDetailView
                    Questions="{Binding DetailQuestions, Source={x:Reference Root}}"
                    DurationText="{Binding DurationText, Source={x:Reference Root}}"
                    HasDuration="False" />
            </Expander>
        </VerticalStackLayout>
    </Border>
</ContentView>
