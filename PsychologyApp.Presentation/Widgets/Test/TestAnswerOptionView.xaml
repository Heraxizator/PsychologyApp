<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.Widgets.Test.TestAnswerOptionView"
             x:Name="Root">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border x:Name="OptionBorder" Style="{StaticResource TestFlatCardStyle}" Margin="0,0,0,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOptionTapped" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger
                        Binding="{TemplateBinding IsSelected}"
                        TargetType="Border"
                        Value="True">
                        <Setter Property="Stroke" Value="{DynamicResource Primary}" />
                        <Setter Property="StrokeThickness" Value="1.5" />
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={DynamicResource PrimaryTint}, Dark={DynamicResource PrimaryTintDark}}" />
                        <Setter Property="Shadow" Value="{StaticResource BrandCardShadow}" />
                    </DataTrigger>
                </Border.Triggers>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" MinimumHeightRequest="{StaticResource TestAnswerOptionMinHeight}">
                    <!-- Single choice: radio ring + inner dot -->
                    <Grid
                        Grid.Column="0"
                        WidthRequest="22"
                        HeightRequest="22"
                        VerticalOptions="Center"
                        IsVisible="{TemplateBinding IsSingleChoice}">
                        <Border
                            WidthRequest="22"
                            HeightRequest="22"
                            StrokeThickness="1.5"
                            Stroke="{DynamicResource Primary}"
                            BackgroundColor="Transparent"
                            VerticalOptions="Center"
                            HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="11" />
                            </Border.StrokeShape>
                        </Border>
                        <Border
                            WidthRequest="10"
                            HeightRequest="10"
                            StrokeThickness="0"
                            BackgroundColor="{DynamicResource Primary}"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            IsVisible="{TemplateBinding IsSelected}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5" />
                            </Border.StrokeShape>
                        </Border>
                    </Grid>
                    <!-- Multiple choice: checkbox square + check -->
                    <Border
                        Grid.Column="0"
                        WidthRequest="22"
                        HeightRequest="22"
                        StrokeThickness="1.5"
                        Stroke="{DynamicResource Primary}"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center"
                        IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="4" />
                        </Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger
                                Binding="{TemplateBinding IsSingleChoice}"
                                TargetType="Border"
                                Value="False">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                            <DataTrigger
                                Binding="{TemplateBinding IsSelected}"
                                TargetType="Border"
                                Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Label
                            IsVisible="{TemplateBinding IsSelected}"
                            Text="{mi:Material Icon=Check}"
                            FontSize="14"
                            TextColor="White"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center" />
                    </Border>
                    <Label
                        Grid.Column="1"
                        Text="{TemplateBinding Text}"
                        Style="{StaticResource BodyStyle}"
                        VerticalOptions="Center"
                        LineBreakMode="WordWrap" />
                </Grid>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
