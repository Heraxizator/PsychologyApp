<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Widgets.Test.TestResultMetricCardView"
             x:Name="Root">

    <Border Style="{StaticResource TestFlatCardStyle}" Margin="0,0,0,8">
        <VerticalStackLayout Spacing="8">
            <Label LineBreakMode="WordWrap">
                <Label.FormattedText>
                    <FormattedString>
                        <Span
                            Text="{Binding MetricName, Source={x:Reference Root}}"
                            FontFamily="{StaticResource SemiBoldFontFamily}"
                            FontSize="{StaticResource SectionTitleFontSize}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        <Span
                            Text=": "
                            FontFamily="{StaticResource BodyFontFamily}"
                            FontSize="{StaticResource BodyFontSize}"
                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                        <Span
                            Text="{Binding MetricValue, Source={x:Reference Root}}"
                            FontFamily="{StaticResource SemiBoldFontFamily}"
                            FontSize="{StaticResource SectionTitleFontSize}"
                            TextColor="{DynamicResource Primary}" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <Label
                Text="{Binding MetricDescription, Source={x:Reference Root}}"
                Style="{StaticResource BodyStyle}"
                HorizontalTextAlignment="Justify"
                LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </Border>

</ContentView>
