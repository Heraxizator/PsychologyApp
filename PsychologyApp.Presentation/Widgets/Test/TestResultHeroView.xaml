<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             xmlns:domain="clr-namespace:PsychologyApp.Domain.Tests;assembly=PsychologyApp.Domain"
             x:Class="PsychologyApp.Presentation.Widgets.Test.TestResultHeroView"
             x:Name="Root">

    <ContentView.Behaviors>
        <behaviors:EmptyStateRevealBehavior />
    </ContentView.Behaviors>

    <Border Style="{StaticResource TestFlatCardStyle}" Margin="0">
        <VerticalStackLayout Spacing="12">
            <Border
                Style="{StaticResource EmptyStateIconHaloStyle}"
                HorizontalOptions="Center">
                <ui:MaterialIconView
                    IconName="CheckCircle"
                    IconSize="32"
                    IconColor="{DynamicResource Primary}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>

            <Border
                IsVisible="{Binding HasTrendBadge, Source={x:Reference Root}}"
                HorizontalOptions="Center"
                Padding="10,4"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={DynamicResource PrimaryTint}, Dark={DynamicResource PrimaryTintDark}}">
                <Border.Triggers>
                    <DataTrigger
                        Binding="{Binding TrendKind, Source={x:Reference Root}}"
                        TargetType="Border"
                        Value="{x:Static domain:TestTrendKind.Worse}">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label
                    Text="{Binding TrendText, Source={x:Reference Root}}"
                    Style="{StaticResource CaptionStyle}"
                    TextColor="{DynamicResource Primary}"
                    FontFamily="{StaticResource SemiBoldFontFamily}">
                    <Label.Triggers>
                        <DataTrigger
                            Binding="{Binding TrendKind, Source={x:Reference Root}}"
                            TargetType="Label"
                            Value="{x:Static domain:TestTrendKind.Worse}">
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

            <Label
                Text="{Binding ScoreTitle, Source={x:Reference Root}}"
                Style="{StaticResource PageTitleStyle}"
                HorizontalTextAlignment="Center" />

            <Label
                Text="{Binding Interpretation, Source={x:Reference Root}}"
                Style="{StaticResource SectionTitleStyle}"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </Border>

</ContentView>
