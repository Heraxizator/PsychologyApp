<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:Class="PsychologyApp.Presentation.Widgets.Audio.MusicTransportControlsView"
             x:Name="Root">

    <ContentView.Behaviors>
        <behaviors:PressFeedbackBehavior AttachToAllTapTargets="True" />
    </ContentView.Behaviors>

    <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="{StaticResource PlayerControlSpacing}">
        <Border
            Grid.Column="0"
            Style="{StaticResource PlayerTransportButtonStyle}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding PlayPreviousCommand, Source={x:Reference Root}}" />
            </Border.GestureRecognizers>
            <ui:MaterialIconView
                IconName="SkipPrevious"
                IconSize="24"
                IconColor="{DynamicResource Primary}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>

        <Border
            Grid.Column="1"
            Style="{StaticResource PlayerPlayButtonStyle}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding TogglePlayPauseCommand, Source={x:Reference Root}}" />
            </Border.GestureRecognizers>
            <Grid>
                <ui:MaterialIconView
                    IconName="PlayArrow"
                    IconSize="28"
                    IconColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <ui:MaterialIconView.Triggers>
                        <DataTrigger
                            Binding="{Binding IsPlaying, Source={x:Reference Root}}"
                            TargetType="ui:MaterialIconView"
                            Value="True">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </ui:MaterialIconView.Triggers>
                </ui:MaterialIconView>
                <ui:MaterialIconView
                    IconName="Pause"
                    IconSize="28"
                    IconColor="White"
                    IsVisible="False"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                    <ui:MaterialIconView.Triggers>
                        <DataTrigger
                            Binding="{Binding IsPlaying, Source={x:Reference Root}}"
                            TargetType="ui:MaterialIconView"
                            Value="True">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </ui:MaterialIconView.Triggers>
                </ui:MaterialIconView>
            </Grid>
        </Border>

        <Border
            Grid.Column="2"
            Style="{StaticResource PlayerTransportButtonStyle}">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding PlayNextCommand, Source={x:Reference Root}}" />
            </Border.GestureRecognizers>
            <ui:MaterialIconView
                IconName="SkipNext"
                IconSize="24"
                IconColor="{DynamicResource Primary}"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentView>
