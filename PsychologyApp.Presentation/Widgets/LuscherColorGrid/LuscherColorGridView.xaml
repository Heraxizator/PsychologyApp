<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Widgets.LuscherColorGrid.LuscherColorGridView"
             x:Name="Root">

    <VerticalStackLayout Margin="{StaticResource LuscherColorGridMargin}" Spacing="12">
        <BoxView
            Margin="20,0"
            HeightRequest="2"
            Color="{DynamicResource Primary}" />

        <Grid
            x:Name="ColorGrid"
            ColumnDefinitions="*,*,*"
            RowDefinitions="Auto,Auto,Auto"
            ColumnSpacing="12"
            RowSpacing="12"
            HorizontalOptions="Center">

            <Border x:Name="RedTile" Grid.Row="0" Grid.Column="0" StrokeThickness="0" IsVisible="{Binding IsRed}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding RedHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Red" CornerRadius="16" Opacity="0.92" />
            </Border>

            <Border x:Name="BrownTile" Grid.Row="0" Grid.Column="1" StrokeThickness="0" IsVisible="{Binding IsBrown}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding BrownHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Brown" CornerRadius="16" Opacity="0.92" />
            </Border>

            <Border x:Name="YellowTile" Grid.Row="0" Grid.Column="2" StrokeThickness="0" IsVisible="{Binding IsYellow}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding YellowHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Yellow" CornerRadius="16" Opacity="0.92" />
            </Border>

            <Border x:Name="GreenTile" Grid.Row="1" Grid.Column="0" StrokeThickness="0" IsVisible="{Binding IsGreen}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GreenHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Green" CornerRadius="16" Opacity="0.92" />
            </Border>

            <Border x:Name="BlueTile" Grid.Row="1" Grid.Column="1" StrokeThickness="0" IsVisible="{Binding IsBlue}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding BlueHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Blue" CornerRadius="16" Opacity="0.92" />
            </Border>

            <Border x:Name="PurpleTile" Grid.Row="1" Grid.Column="2" StrokeThickness="0" IsVisible="{Binding IsPurple}">
                <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding PurpleHandler}" /></Border.GestureRecognizers>
                <BoxView Color="Purple" CornerRadius="16" Opacity="0.92" />
            </Border>

            <HorizontalStackLayout
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Spacing="12"
                HorizontalOptions="Center">
                <Border x:Name="GrayTile" StrokeThickness="0" IsVisible="{Binding IsGray}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding GrayHandler}" /></Border.GestureRecognizers>
                    <BoxView Color="Gray" CornerRadius="16" Opacity="0.92" />
                </Border>
                <Border x:Name="BlackTile" StrokeThickness="0" IsVisible="{Binding IsBlack}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding BlackHandler}" /></Border.GestureRecognizers>
                    <BoxView Color="Black" CornerRadius="16" Opacity="0.92" />
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <BoxView
            Margin="20,0"
            HeightRequest="2"
            Color="{DynamicResource Primary}" />
    </VerticalStackLayout>
</ContentView>
