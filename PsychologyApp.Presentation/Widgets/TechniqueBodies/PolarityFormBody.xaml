<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.Widgets.TechniqueBodies.PolarityFormBody">
    <StackLayout Spacing="8">
        <Border Style="{StaticResource BrandCardStyle}" Margin="0,0,0,8">
            <StackLayout Spacing="8">
                <Label Text="{Binding FormSectionTitle}" Style="{StaticResource SectionTitleStyle}" />
                <ui:TextEntryView TitleText="{Binding FirstPolarityLabel}" PlaceholderText="{Binding NegativePlaceholder}" BodyText="{Binding Negative}" />
                <ui:TextEntryView TitleText="{Binding SecondPolarityLabel}" PlaceholderText="{Binding PositivePlaceholder}" BodyText="{Binding Positive}" />
                <ui:ButtonView
                    BodyText="{Binding AddButtonText}"
                    TapCommand="{Binding Add}" />
            </StackLayout>
        </Border>
        <StackLayout x:Name="PolarityItemsStack" IsVisible="{Binding IsFull}" Spacing="8" BindableLayout.ItemsSource="{Binding polarities}">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                        <Border.Behaviors>
                            <behaviors:ListItemRevealBehavior />
                        </Border.Behaviors>
                        <StackLayout Spacing="8">
                            <Label Text="{Binding Id}" Style="{StaticResource BodyStyle}" />
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding Positive}" Style="{StaticResource BodyStyle}" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="24"
                                    VerticalOptions="Center"
                                    TextColor="{DynamicResource Primary}"
                                    Text="{mi:Material Icon=Remove}" />
                                <Label
                                    Grid.Column="2"
                                    Text="{Binding Negative}"
                                    HorizontalTextAlignment="End"
                                    Style="{StaticResource BodyStyle}" />
                            </Grid>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </StackLayout>
    </StackLayout>
</ContentView>
