<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:Class="PsychologyApp.Presentation.UI.Components.EntryBoxView"
             x:Name="Root">
    <VerticalStackLayout Spacing="{StaticResource LayoutSpacing}">
        <Label
            Text="{Binding TitleText, Source={x:Reference Root}}"
            Style="{StaticResource SectionTitleStyle}" />

        <VerticalStackLayout
            Spacing="{StaticResource LayoutSpacing}"
            BindableLayout.ItemsSource="{Binding BodySource, Source={x:Reference Root}}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="ui:EntryItem">
                    <ui:TextEntryView
                        TitleText="{Binding Title}"
                        BodyText="{Binding Text, Mode=TwoWay}"
                        PlaceholderText="{Binding Placeholder}" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>
