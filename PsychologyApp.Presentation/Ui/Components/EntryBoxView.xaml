<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:Class="PsychologyApp.Presentation.UI.Components.EntryBoxView">
<ContentView.ControlTemplate>
        <ControlTemplate>

            <Frame>
                <StackLayout>
                    <Label
                        Text="Форма"
                        FontSize="18"
                        TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                    <StackLayout
                        Margin="0, 5, 0, 0"
                        BindableLayout.ItemsSource="{TemplateBinding BodySource}">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="ui:EntryItem">
                                <ui:TextEntryView
                                    TitleText="{Binding Title}"
                                    BodyText="{Binding Text}"
                                    PlaceholderText="{Binding Placeholder}"/>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>

                    </StackLayout>

                </StackLayout>

            </Frame>

        </ControlTemplate>
    </ContentView.ControlTemplate>


</ContentView>