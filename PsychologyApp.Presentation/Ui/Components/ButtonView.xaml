<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.ButtonView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border
                x:Name="ActionBorder"
                Style="{StaticResource PrimaryActionBorderStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{TemplateBinding TapCommand}" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger
                        Binding="{TemplateBinding Variant}"
                        TargetType="Border"
                        Value="Primary">
                        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                        <Setter Property="Stroke" Value="Transparent" />
                    </DataTrigger>
                    <DataTrigger
                        Binding="{TemplateBinding IsCompact}"
                        TargetType="Border"
                        Value="True">
                        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
                        <Setter Property="WidthRequest" Value="125" />
                        <Setter Property="HeightRequest" Value="35" />
                        <Setter Property="VerticalOptions" Value="Center" />
                    </DataTrigger>
                </Border.Triggers>
                <Label
                    x:Name="ActionLabel"
                    Style="{StaticResource PrimaryActionLabelStyle}"
                    Text="{TemplateBinding BodyText}">
                    <Label.Triggers>
                        <DataTrigger
                            Binding="{TemplateBinding IsCompact}"
                            TargetType="Label"
                            Value="True">
                            <Setter Property="FontSize" Value="14" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="FontFamily" Value="RobotoMedium" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
