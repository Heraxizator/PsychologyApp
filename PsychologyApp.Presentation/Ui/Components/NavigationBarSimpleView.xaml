<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.UI.Components.NavigationBarSimpleView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Grid Margin="0,0,0,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <Label
                    Grid.Column="0"
                    Style="{StaticResource NavBackIconStyle}"
                    Text="{mi:Material Icon=KeyboardArrowLeft}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding BackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label
                    Grid.Column="1"
                    Text="{TemplateBinding TitleText}"
                    Style="{StaticResource NavTitleStyle}"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center" />
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
