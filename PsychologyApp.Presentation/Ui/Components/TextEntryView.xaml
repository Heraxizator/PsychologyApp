<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.TextEntryView"
             x:Name="Root">
    <Border
        x:Name="InputBorder"
        Style="{StaticResource InputBorderStyle}">
        <VerticalStackLayout Spacing="4">
            <Label
                Text="{Binding TitleText, Source={x:Reference Root}}"
                Style="{StaticResource CaptionStyle}">
                <Label.Triggers>
                    <DataTrigger
                        Binding="{Binding TitleText, Source={x:Reference Root}}"
                        TargetType="Label"
                        Value="">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Entry
                x:Name="InputEntry"
                Style="{StaticResource InputTextStyle}"
                MinimumHeightRequest="44"
                Keyboard="Text"
                Placeholder="{Binding PlaceholderText, Source={x:Reference Root}}"
                Text="{Binding BodyText, Source={x:Reference Root}, Mode=TwoWay}"
                Focused="OnInputFocused"
                Unfocused="OnInputUnfocused"
                TextChanged="OnInputTextChanged" />
        </VerticalStackLayout>
    </Border>
</ContentView>
