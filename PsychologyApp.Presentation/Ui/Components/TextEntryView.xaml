<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.UI.Components.TextEntryView">
<ContentView.ControlTemplate>
        <ControlTemplate>
            <Border 
                StrokeThickness="1"
                StrokeShape="RoundRectangle 25"
                BackgroundColor="White"
                Stroke="{StaticResource Secondary}">
                <StackLayout Margin="15, 5, 15, 0" VerticalOptions="CenterAndExpand">
                    <Label 
                        TextColor="{StaticResource TextPrimary}"
                        Padding="0"
                        FontFamily="RobotoRegular"
                        Text="{TemplateBinding TitleText}"
                        FontSize="14"/>
                    <Entry
                        Margin="0, -10, 0, 0"
                        PlaceholderColor="{StaticResource Secondary}"
                        Placeholder="{TemplateBinding PlaceholderText}"
                        FontSize="14"
                        Keyboard="Text"
                        Text="{TemplateBinding BodyText}"
                        FontFamily="RobotoRegular"
                        TextColor="{StaticResource TextPrimary}"
                        VerticalTextAlignment="Center"/>
                </StackLayout>

            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>


</ContentView>