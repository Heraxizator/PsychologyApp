<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.TextEditorView"
             x:Name="Root">
    <Border
        x:Name="InputBorder"
        Style="{StaticResource InputBorderStyle}">
        <VerticalStackLayout Spacing="4" MinimumHeightRequest="90">
            <Label
                Text="{Binding TitleText, Source={x:Reference Root}}"
                Style="{StaticResource CaptionStyle}" />
            <Editor
                x:Name="InputEditor"
                Style="{StaticResource InputEditorStyle}"
                MaxLength="1000"
                Placeholder="{Binding PlaceholderText, Source={x:Reference Root}}"
                Text="{Binding BodyText, Source={x:Reference Root}, Mode=TwoWay}"
                VerticalOptions="FillAndExpand"
                Focused="OnInputFocused"
                Unfocused="OnInputUnfocused" />
        </VerticalStackLayout>
    </Border>
</ContentView>
