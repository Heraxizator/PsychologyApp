<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.SettingPickerRowView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Grid HeightRequest="50" ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label
                    Grid.Column="0"
                    Text="{TemplateBinding LabelText}"
                    FontSize="15"
                    VerticalOptions="Center"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                <Picker
                    Grid.Column="1"
                    WidthRequest="125"
                    FontSize="15"
                    Title="{TemplateBinding PickerTitle}"
                    TitleColor="{DynamicResource Primary}"
                    TextColor="{DynamicResource Secondary}"
                    BackgroundColor="Transparent"
                    HorizontalOptions="End"
                    HorizontalTextAlignment="Start"
                    ItemsSource="{TemplateBinding ItemsSource}"
                    SelectedItem="{TemplateBinding SelectedItem, Mode=TwoWay}" />
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
