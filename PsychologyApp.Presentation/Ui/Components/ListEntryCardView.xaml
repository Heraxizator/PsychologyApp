<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.ListEntryCardView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Frame>
                <StackLayout>
                    <Label Text="{TemplateBinding Title}" Style="{StaticResource BodyStyle}" />
                    <Label Text="{TemplateBinding Body}" Style="{StaticResource BodyStyle}" />
                </StackLayout>
            </Frame>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
