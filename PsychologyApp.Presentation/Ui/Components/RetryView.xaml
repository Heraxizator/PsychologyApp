<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.UI.Components.RetryView">
<ContentView.ControlTemplate>
        <ControlTemplate>
            <StackLayout>

                <Label 
                    Text="{TemplateBinding FailedText}"
                    TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                    FontSize="16"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center" />

                <Label
                    Text="{TemplateBinding RetryText}"
                    TextColor="{AppThemeBinding Light={StaticResource AccentTextLight}, Dark={StaticResource Secondary}}"
                    FontSize="15"
                    VerticalOptions="CenterAndExpand"
                    HorizontalOptions="CenterAndExpand">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding RetryCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </StackLayout>
        </ControlTemplate>
    </ContentView.ControlTemplate>
    
    
</ContentView>
