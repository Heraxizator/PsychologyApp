<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.SettingsLinkCardView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Frame Margin="0,10,0,0">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Command="{TemplateBinding TapCommand}" />
                </Frame.GestureRecognizers>
                <StackLayout>
                    <Label Text="{TemplateBinding Title}" Style="{StaticResource SectionTitleStyle}" />
                    <Label
                        Margin="0,5,0,0"
                        Text="{TemplateBinding Subtitle}"
                        Style="{StaticResource BodyStyle}" />
                </StackLayout>
            </Frame>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
