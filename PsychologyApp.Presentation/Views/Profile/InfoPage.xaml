<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Profile.InfoPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Profile"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Common.Behaviors"
             x:DataType="vm:InfoViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">
<StackLayout Margin="{StaticResource LayoutPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">
        <StackLayout.Behaviors>
            <behaviors:StaggerChildrenBehavior />
        </StackLayout.Behaviors>

        <ui:NavigationBarSimpleView
                BackCommand="{Binding BackCommand}"
                TitleText="{Binding PageTitle}"/>

        <Label
                HorizontalTextAlignment="Justify"
                Text="{Binding AboutBody}"
                Style="{StaticResource BodyStyle}" />

        <Label
                Text="{Binding AppVersionText}"
                Style="{StaticResource CaptionStyle}"
                TextColor="{DynamicResource Primary}" />

        </StackLayout>

</ContentPage>
