<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Clean.MusicPlayerPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Clean"
             xmlns:clean="clr-namespace:PsychologyApp.Presentation.Models.Clean"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Common.Behaviors"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="vm:MusicPlayerViewModel"
             x:Name="PageRoot"
             Shell.NavBarIsVisible="True"
             Title="{Binding PageTitle}">

    <Grid
        VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <Grid
            IsVisible="{Binding IsDone}"
            Margin="{StaticResource LayoutTabPageMarginThickness}"
            RowDefinitions="Auto,*,Auto,Auto">
            <Grid.Behaviors>
                <behaviors:RevealOnAppearingBehavior RevealOnTabAppearOnly="True" />
            </Grid.Behaviors>

            <ui:TextEntryView
                Grid.Row="0"
                Margin="0,0,0,8"
                PlaceholderText="{Binding SearchPlaceholder}"
                BodyText="{Binding SearchText, Mode=TwoWay}" />

            <CollectionView
                Grid.Row="1"
                x:Name="Musics"
                VerticalOptions="FillAndExpand"
                VerticalScrollBarVisibility="Never"
                ItemsSource="{Binding FilteredItems}">
                <CollectionView.EmptyView>
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource BodyStyle}"
                        Text="{Binding NoPrayersFoundText}"
                        IsVisible="{Binding IsSearchEmptyVisible}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="clean:Audio">
                        <ui:MusicListCardView
                            Title="{Binding Name}"
                            Subtitle="{Binding Description}"
                            IsActive="{Binding IsActive}"
                            IsPlayingThis="{Binding IsPlayingThis}"
                            ShowOfflineBadge="{Binding IsCached}"
                            OfflineBadgeText="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OfflineBadgeText}"
                            TapCommand="{Binding ClickCommand}">
                            <ui:MusicListCardView.Behaviors>
                                <behaviors:ListItemRevealBehavior />
                            </ui:MusicListCardView.Behaviors>
                        </ui:MusicListCardView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border
                Grid.Row="2"
                Margin="0,8,0,8"
                IsVisible="{Binding HasActiveTrack}"
                Style="{StaticResource BrandCardStyle}"
                Padding="12">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding NowPlayingLabel}" Style="{StaticResource CaptionStyle}" />
                            <Label Text="{Binding ActiveTrackTitle}" Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="{Binding ProgressDisplay}" Style="{StaticResource CaptionStyle}" />
                        </VerticalStackLayout>
                        <ui:ButtonView
                            Grid.Column="1"
                            IsCompact="True"
                            BodyText="{Binding PlayNextButtonText}"
                            TapCommand="{Binding PlayNextCommand}" />
                        <ui:ButtonView
                            Grid.Column="2"
                            IsCompact="True"
                            BodyText="{Binding PlayPauseGlyph}"
                            TapCommand="{Binding TogglePlayPauseCommand}" />
                    </Grid>
                    <Label
                        IsVisible="{Binding ShowBufferingOverlay}"
                        Text="{Binding BufferingText}"
                        Style="{StaticResource CaptionStyle}"
                        TextColor="{DynamicResource Primary}" />
                </VerticalStackLayout>
            </Border>

            <ui:TextBoxView
                Grid.Row="3"
                Margin="0,0,0,10"
                HeaderText="{Binding MoreInfoHeader}"
                BodyText="{Binding MoreInfoBody}" />

            <toolkit:MediaElement
                x:Name="Player"
                Grid.Row="3"
                IsVisible="False"
                ShouldAutoPlay="True"
                MediaEnded="OnMediaEnded"
                MediaFailed="OnMediaFailed" />
        </Grid>

        <ui:RetryView
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding LoadFailedText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding Reload}" />
    </Grid>
</ContentPage>
