<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Physics.StartPhysicsPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Physics"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Common.Behaviors"
             x:DataType="vm:StartPhysicsViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding PageTitle}">

    <Grid VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <ScrollView
            IsVisible="{Binding IsDone}"
            VerticalScrollBarVisibility="Never">
            <VerticalStackLayout
                x:Name="ContentStack"
                Margin="{StaticResource LayoutTabPageMarginThickness}"
                Spacing="{StaticResource LayoutSpacing}">
                    <VerticalStackLayout.Behaviors>
                        <behaviors:RevealOnAppearingBehavior RevealOnTabAppearOnly="True" />
                    </VerticalStackLayout.Behaviors>
                    <ui:TextBoxView
                        HeaderText="{Binding ExplanationHeader}"
                        BodyText="{Binding ExplanationBody}" />
                    <ui:TextBoxView
                        HeaderText="{Binding DescriptionHeader}"
                        BodyText="{Binding DescriptionBody}" />
                    <ui:AlgorithmBoxView
                        TitleText="{Binding AlgorithmHeader}"
                        BodySource="{Binding AlgorithmSteps}" />
                    <ui:ButtonView
                        BodyText="{Binding StartButtonText}"
                        TapCommand="{Binding StartCommand}" />
            </VerticalStackLayout>
        </ScrollView>

        <ui:ProgressBarView
            x:Name="LoadingProgress"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsLoadingOverlayVisible}"
            IsLoading="{Binding IsLoadingOverlayVisible}"
            ProgressText="{Binding LoadingText}"
            CancelCommand="{Binding Cancel}" />

        <ui:RetryView
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding FailedText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding Reload}" />
    </Grid>
</ContentPage>
