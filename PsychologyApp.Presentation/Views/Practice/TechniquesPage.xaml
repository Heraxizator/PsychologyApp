<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Practice.TechniquesPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Practice"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Common.Behaviors"
             xmlns:technique="clr-namespace:PsychologyApp.Presentation.Models.Practice"
             x:DataType="vm:TechniquesViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ProfileToolbarText}" Command="{Binding OpenProfileCommand}" />
    </ContentPage.ToolbarItems>

    <Grid
        VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <CollectionView
            x:Name="TechniquesCollectionView"
            Margin="{StaticResource LayoutTabPageMarginThickness}"
            ItemsSource="{Binding Techniques}"
            IsVisible="{Binding IsDone}"
            SelectionMode="Single"
            VerticalScrollBarVisibility="Never"
            HorizontalScrollBarVisibility="Never">
            <CollectionView.Behaviors>
                <behaviors:RevealOnAppearingBehavior RevealOnTabAppearOnly="True" />
            </CollectionView.Behaviors>

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <VerticalStackLayout Spacing="16" Padding="0,0,0,8">
                    <VerticalStackLayout.Behaviors>
                        <behaviors:StaggerChildrenBehavior />
                    </VerticalStackLayout.Behaviors>

                    <Border Style="{StaticResource BrandCardStyle}" Padding="16">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding TodayTechniqueItem.TapCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Label
                                    Grid.Column="0"
                                    Text="{Binding TodayForYouLabel}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextColor="{DynamicResource Primary}" />
                                <Label
                                    Grid.Column="1"
                                    IsVisible="{Binding HasStreak}"
                                    Text="{Binding StreakDisplay}"
                                    Style="{StaticResource CaptionStyle}"
                                    HorizontalTextAlignment="End" />
                            </Grid>
                            <Label
                                Text="{Binding TodayTechniqueItem.Title}"
                                Style="{StaticResource SectionTitleStyle}" />
                            <Label
                                Text="{Binding TodayTechniqueItem.Subtitle}"
                                Style="{StaticResource BodyStyle}" />
                            <Label
                                Text="{Binding TodayTechniqueItem.Theme}"
                                Style="{StaticResource CaptionStyle}"
                                TextColor="{DynamicResource Primary}" />
                            <ui:ButtonView
                                Margin="0,4,0,0"
                                BodyText="{Binding TodayStartPracticeText}"
                                TapCommand="{Binding StartTodayPracticeCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource BrandCardStyle}" Padding="12,14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding TodayMoodQuestion}" Style="{StaticResource BodyStyle}" />
                            <HorizontalStackLayout
                                HorizontalOptions="Center"
                                Spacing="8">
                                <ui:ButtonView IsCompact="True" BodyText="😞" TapCommand="{Binding RecordMood1Command}" />
                                <ui:ButtonView IsCompact="True" BodyText="😕" TapCommand="{Binding RecordMood2Command}" />
                                <ui:ButtonView IsCompact="True" BodyText="😐" TapCommand="{Binding RecordMood3Command}" />
                                <ui:ButtonView IsCompact="True" BodyText="🙂" TapCommand="{Binding RecordMood4Command}" />
                                <ui:ButtonView IsCompact="True" BodyText="😊" TapCommand="{Binding RecordMood5Command}" />
                            </HorizontalStackLayout>
                            <Label
                                IsVisible="{Binding HasTodayMood}"
                                Text="{Binding TodayMoodDisplay}"
                                HorizontalTextAlignment="Center"
                                Style="{StaticResource CaptionStyle}"
                                TextColor="{DynamicResource Primary}" />
                            <VerticalStackLayout
                                IsVisible="{Binding HasMoodHistory}"
                                Spacing="4"
                                Margin="0,4,0,0">
                                <Label
                                    Text="{Binding MoodHistoryTitle}"
                                    Style="{StaticResource CaptionStyle}"
                                    TextColor="{DynamicResource Gray500}" />
                                <VerticalStackLayout
                                    BindableLayout.ItemsSource="{Binding MoodHistory}"
                                    Spacing="2">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="technique:MoodHistoryItem">
                                            <Label Text="{Binding DisplayText}" Style="{StaticResource CaptionStyle}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,4,0,0">
                        <Label
                            Grid.Column="0"
                            Text="{Binding PracticeCatalogLabel}"
                            Style="{StaticResource SectionTitleStyle}"
                            VerticalOptions="Center" />
                        <ui:ButtonView
                            Grid.Column="1"
                            IsCompact="True"
                            Variant="Secondary"
                            BodyText="{Binding CreateButtonText}"
                            TapCommand="{Binding ConstructorTapped}" />
                    </Grid>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="technique:TechniqueItem">
                    <ui:TechniqueListCardView
                        Number="{Binding Number}"
                        Date="{Binding Date}"
                        Image="{Binding Image}"
                        Title="{Binding Title}"
                        Subtitle="{Binding Subtitle}"
                        Theme="{Binding Theme}"
                        Author="{Binding Author}"
                        Active="{Binding Active}"
                        TapCommand="{Binding TapCommand}">
                        <ui:TechniqueListCardView.Behaviors>
                            <behaviors:ListItemRevealBehavior />
                        </ui:TechniqueListCardView.Behaviors>
                    </ui:TechniqueListCardView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <StackLayout Padding="{StaticResource LayoutEmptyPaddingThickness}" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label HorizontalTextAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="{Binding PracticeEmptyTitle}" />
                    <Label HorizontalTextAlignment="Center" Style="{StaticResource BodyStyle}" Text="{Binding PracticeEmptyBody}" />
                </StackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

        <ui:ProgressBarView
            x:Name="LoadingProgress"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsLoadingOverlayVisible}"
            IsLoading="{Binding IsLoadingOverlayVisible}"
            ProgressText="{Binding LoadingText}">
            <ui:ProgressBarView.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Cancel}" />
            </ui:ProgressBarView.GestureRecognizers>
        </ui:ProgressBarView>

        <ui:RetryView
            VerticalOptions="Center"
            HorizontalOptions="Center"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding FailedText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding Reload}" />

    </Grid>
</ContentPage>
