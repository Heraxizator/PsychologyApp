<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.RatingEntryView"
             x:Name="Root"
             HorizontalOptions="Fill">
    <Border Style="{StaticResource InputBorderStyle}">
        <VerticalStackLayout Spacing="8">
            <Label
                Text="{Binding TitleText, Source={x:Reference Root}}"
                Style="{StaticResource CaptionStyle}"
                Margin="2,0,0,0">
                <Label.Triggers>
                    <DataTrigger
                        Binding="{Binding TitleText, Source={x:Reference Root}}"
                        TargetType="Label"
                        Value="">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Label
                Text="{Binding ValueDisplay, Source={x:Reference Root}}"
                Style="{StaticResource BodyStyle}"
                HorizontalTextAlignment="Center" />
            <Slider
                x:Name="RatingSlider"
                Minimum="{Binding Minimum, Source={x:Reference Root}}"
                Maximum="{Binding Maximum, Source={x:Reference Root}}"
                Value="{Binding SliderValue, Source={x:Reference Root}, Mode=TwoWay}"
                ValueChanged="OnSliderValueChanged" />
        </VerticalStackLayout>
    </Border>
</ContentView>
