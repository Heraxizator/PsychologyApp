<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:physics="clr-namespace:PsychologyApp.Presentation.Models.Physics"
             x:Class="PsychologyApp.Presentation.UI.Components.PhysicsReasonCardView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border Style="{StaticResource TechniqueListCardStyle}">
                <VerticalStackLayout Spacing="8">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding ToggleExpandCommand}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FormattedText="{TemplateBinding TitleFormatted}"
                            Style="{StaticResource ListRowTitleStyle}" />
                        <Label
                            FormattedText="{TemplateBinding SubtitleFormatted}"
                            Style="{StaticResource CaptionStyle}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        StyleId="ExpandedSection"
                        IsVisible="False"
                        Spacing="6">
                        <Label
                            Style="{StaticResource ListRowTitleStyle}"
                            Text="{TemplateBinding SolutionHeader}" />
                        <Label
                            Style="{StaticResource BodyStyle}"
                            Text="{TemplateBinding Solution}" />
                        <Label
                            Style="{StaticResource ListRowTitleStyle}"
                            Text="{TemplateBinding RecommendedPracticesLabel}" />
                        <VerticalStackLayout BindableLayout.ItemsSource="{TemplateBinding SuggestedTechniques}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="physics:PhysicsTechniqueSuggestion">
                                    <ui:ButtonView
                                        Margin="0,4,0,0"
                                        Variant="Secondary"
                                        IsCompact="True"
                                        BodyText="{Binding Title}"
                                        TapCommand="{Binding OpenCommand}" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
