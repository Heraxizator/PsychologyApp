<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.UI.Components.TextEditorView"
             x:Name="Root"
             HorizontalOptions="Fill">
    <Border
        x:Name="InputBorder"
        Style="{StaticResource InputBorderStyle}">
        <Border.Triggers>
            <DataTrigger
                Binding="{Binding Variant, Source={x:Reference Root}}"
                TargetType="Border"
                Value="Plain">
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Padding" Value="0" />
            </DataTrigger>
        </Border.Triggers>
        <VerticalStackLayout Spacing="6">
            <Label
                Text="{Binding TitleText, Source={x:Reference Root}}"
                Style="{StaticResource CaptionStyle}"
                Margin="2,0,0,0">
                <Label.Triggers>
                    <DataTrigger
                        Binding="{Binding TitleText, Source={x:Reference Root}}"
                        TargetType="Label"
                        Value="">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Editor
                x:Name="InputEditor"
                Style="{StaticResource InputEditorStyle}"
                MaxLength="1000"
                Placeholder="{Binding PlaceholderText, Source={x:Reference Root}}"
                Text="{Binding BodyText, Source={x:Reference Root}, Mode=TwoWay}"
                VerticalOptions="Fill"
                Focused="OnInputFocused"
                Unfocused="OnInputUnfocused" />
        </VerticalStackLayout>
    </Border>
</ContentView>
