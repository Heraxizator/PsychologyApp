<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.UI.Components.MusicListCardView"
             x:Name="Root">
    <Border x:Name="CardBorder" Style="{StaticResource MusicListRowStyle}">
        <Border.Triggers>
            <DataTrigger
                Binding="{Binding IsActive, Source={x:Reference Root}}"
                TargetType="Border"
                Value="True">
                <Setter Property="Stroke" Value="{DynamicResource Primary}" />
                <Setter Property="StrokeThickness" Value="2" />
            </DataTrigger>
        </Border.Triggers>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding TapCommand, Source={x:Reference Root}}" />
        </Border.GestureRecognizers>
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Border
                Grid.Column="0"
                WidthRequest="52"
                HeightRequest="52"
                StrokeThickness="0"
                BackgroundColor="{DynamicResource PrimaryTint}"
                VerticalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Label
                    x:Name="PlayIcon"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    TextColor="{DynamicResource Primary}"
                    Text="{mi:Material Icon=PlayArrow}" />
            </Border>
            <VerticalStackLayout
                Grid.Column="1"
                Spacing="4"
                VerticalOptions="Center">
                <Label
                    Text="{Binding Title, Source={x:Reference Root}}"
                    Style="{StaticResource ListRowTitleStyle}"
                    MaxLines="2"
                    LineBreakMode="TailTruncation" />
                <Label
                    Text="{Binding Subtitle, Source={x:Reference Root}}"
                    Style="{StaticResource CaptionStyle}"
                    MaxLines="2"
                    LineBreakMode="TailTruncation" />
                <Label
                    IsVisible="{Binding ShowOfflineBadge, Source={x:Reference Root}}"
                    Text="{Binding OfflineBadgeText, Source={x:Reference Root}}"
                    Style="{StaticResource CaptionStyle}"
                    TextColor="{DynamicResource Primary}" />
            </VerticalStackLayout>
            <Label
                Grid.Column="2"
                VerticalOptions="Center"
                TextColor="{AppThemeBinding Light={StaticResource TextTertiaryLight}, Dark={StaticResource TextSecondaryDark}}"
                Text="{mi:Material Icon=KeyboardArrowRight}" />
        </Grid>
    </Border>
</ContentView>
