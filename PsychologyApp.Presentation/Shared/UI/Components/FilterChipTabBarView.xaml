<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:common="clr-namespace:PsychologyApp.Presentation.Entities.FilterChip"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.FilterChipTabBarView"
             x:Name="BarRoot">
    <CollectionView
        ItemsSource="{Binding ItemsSource, Source={x:Reference BarRoot}}"
        HeightRequest="40"
        SelectionMode="None"
        HorizontalScrollBarVisibility="Never"
        VerticalScrollBarVisibility="Never">
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="common:FilterChipTabItem">
                <ui:FilterChipView
                    TitleText="{Binding Title}"
                    IsSelected="{Binding IsSelected}"
                    TapCommand="{Binding TapCommand, Source={x:Reference BarRoot}}"
                    CommandParameter="{Binding Key}" />
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentView>
