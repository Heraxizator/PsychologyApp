<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.ProgressBarView">

    <ContentView.Behaviors>
        <behaviors:PressFeedbackBehavior AttachToTappableLabels="True" />
    </ContentView.Behaviors>

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <VerticalStackLayout Spacing="12">
                <ActivityIndicator
                    IsRunning="{TemplateBinding IsLoading}"
                    Color="{DynamicResource Primary}" />
                <Label
                    Text="{TemplateBinding ProgressText}"
                    HorizontalOptions="Center"
                    Style="{StaticResource BodyStyle}" />
                <Label
                    IsVisible="{TemplateBinding HasCancel}"
                    Text="{TemplateBinding CancelText}"
                    HorizontalOptions="Center"
                    Style="{StaticResource NavActionLabelStyle}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding CancelCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </VerticalStackLayout>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
