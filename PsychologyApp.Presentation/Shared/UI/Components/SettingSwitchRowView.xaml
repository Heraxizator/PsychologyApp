<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.SettingSwitchRowView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Grid MinimumHeightRequest="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label
                    Grid.Column="0"
                    Text="{TemplateBinding LabelText}"
                    Style="{StaticResource BodyStyle}"
                    VerticalOptions="Center" />
                <Switch
                    Grid.Column="1"
                    OnColor="{DynamicResource Primary}"
                    IsToggled="{TemplateBinding IsToggled, Mode=TwoWay}" />
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
