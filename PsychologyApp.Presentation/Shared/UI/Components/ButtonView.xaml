<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.ButtonView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Border
                x:Name="ActionBorder"
                Style="{StaticResource PrimaryActionBorderStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{TemplateBinding TapCommand}" />
                </Border.GestureRecognizers>
                <Border.Triggers>
                    <DataTrigger
                        Binding="{TemplateBinding Variant}"
                        TargetType="Border"
                        Value="Secondary">
                        <Setter Property="Style" Value="{StaticResource OutlinedActionBorderStyle}" />
                    </DataTrigger>
                    <MultiTrigger TargetType="Border">
                        <MultiTrigger.Conditions>
                            <BindingCondition Binding="{TemplateBinding Variant}" Value="Primary" />
                            <BindingCondition Binding="{TemplateBinding IsCompact}" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Style" Value="{StaticResource CompactPrimaryBorderStyle}" />
                    </MultiTrigger>
                    <MultiTrigger TargetType="Border">
                        <MultiTrigger.Conditions>
                            <BindingCondition Binding="{TemplateBinding Variant}" Value="Secondary" />
                            <BindingCondition Binding="{TemplateBinding IsCompact}" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Style" Value="{StaticResource CompactOutlinedBorderStyle}" />
                    </MultiTrigger>
                    <DataTrigger
                        Binding="{TemplateBinding IsEnabled}"
                        TargetType="Border"
                        Value="False">
                        <Setter Property="Opacity" Value="0.45" />
                        <Setter Property="InputTransparent" Value="True" />
                    </DataTrigger>
                </Border.Triggers>
                <Label
                    x:Name="ActionLabel"
                    Style="{StaticResource PrimaryActionLabelStyle}"
                    Text="{TemplateBinding BodyText}">
                    <Label.Triggers>
                        <DataTrigger
                            Binding="{TemplateBinding Variant}"
                            TargetType="Label"
                            Value="Secondary">
                            <Setter Property="Style" Value="{StaticResource OutlinedActionLabelStyle}" />
                        </DataTrigger>
                        <MultiTrigger TargetType="Label">
                            <MultiTrigger.Conditions>
                                <BindingCondition Binding="{TemplateBinding Variant}" Value="Primary" />
                                <BindingCondition Binding="{TemplateBinding IsCompact}" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Style" Value="{StaticResource CompactPrimaryLabelStyle}" />
                        </MultiTrigger>
                        <MultiTrigger TargetType="Label">
                            <MultiTrigger.Conditions>
                                <BindingCondition Binding="{TemplateBinding Variant}" Value="Secondary" />
                                <BindingCondition Binding="{TemplateBinding IsCompact}" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Style" Value="{StaticResource CompactOutlinedLabelStyle}" />
                        </MultiTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
