<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.SectionHeaderView">

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label
                        Text="{TemplateBinding TitleText}"
                        Style="{StaticResource SectionTitleStyle}" />
                    <Label
                        IsVisible="{TemplateBinding HasSubtitle}"
                        Text="{TemplateBinding SubtitleText}"
                        Style="{StaticResource CaptionStyle}" />
                </VerticalStackLayout>
                <ui:ButtonView
                    Grid.Column="1"
                    IsVisible="{TemplateBinding HasAction}"
                    IsCompact="True"
                    Variant="Secondary"
                    BodyText="{TemplateBinding ActionText}"
                    TapCommand="{TemplateBinding ActionCommand}" />
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
