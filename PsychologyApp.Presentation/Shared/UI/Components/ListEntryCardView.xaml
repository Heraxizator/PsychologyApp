<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.ListEntryCardView"
             x:Name="Root">
    <Border Style="{StaticResource BrandCardStyle}">
        <VerticalStackLayout Spacing="4">
            <Label Text="{Binding Title, Source={x:Reference Root}}" Style="{StaticResource BodyStyle}" />
            <Label Text="{Binding Body, Source={x:Reference Root}}" Style="{StaticResource BodyStyle}" />
        </VerticalStackLayout>
    </Border>
</ContentView>
