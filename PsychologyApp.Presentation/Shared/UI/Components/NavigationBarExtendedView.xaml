<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.NavigationBarExtendedView">

    <ContentView.Behaviors>
        <behaviors:PressFeedbackBehavior AttachToTappableLabels="True" />
    </ContentView.Behaviors>

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <Grid
                Margin="{StaticResource NavBarBottomMargin}"
                ColumnDefinitions="44,*,Auto"
                ColumnSpacing="8"
                MinimumHeightRequest="48">
                <BoxView
                    Grid.ColumnSpan="3"
                    HeightRequest="1"
                    VerticalOptions="End"
                    Color="{AppThemeBinding Light={StaticResource NeutralBorder}, Dark={StaticResource InputBorderDark}}" />
                <Label
                    Grid.Column="0"
                    Style="{StaticResource NavBackIconStyle}"
                    Text="{mi:Material Icon=KeyboardArrowLeft}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding BackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
                <Label
                    Grid.Column="1"
                    Text="{TemplateBinding TitleText}"
                    Style="{StaticResource NavTitleStyle}"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation"
                    MaxLines="1" />
                <Label
                    Grid.Column="2"
                    IsVisible="{TemplateBinding ExtensionEnabled}"
                    Text="{TemplateBinding ExtensionText}"
                    Style="{StaticResource NavActionLabelStyle}"
                    HorizontalOptions="End"
                    LineBreakMode="TailTruncation"
                    MaxLines="1">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{TemplateBinding ExtensionCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
