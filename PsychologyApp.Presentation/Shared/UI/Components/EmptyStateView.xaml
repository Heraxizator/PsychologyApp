<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.Shared.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Shared.Common.Behaviors"
             x:Class="PsychologyApp.Presentation.Shared.UI.Components.EmptyStateView">

    <ContentView.Behaviors>
        <behaviors:EmptyStateRevealBehavior />
    </ContentView.Behaviors>

    <ContentView.ControlTemplate>
        <ControlTemplate>
            <VerticalStackLayout
                Padding="{StaticResource LayoutEmptyPaddingThickness}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="12"
                MaximumWidthRequest="320">
                <Border
                    IsVisible="{TemplateBinding HasIcon}"
                    Style="{StaticResource EmptyStateIconHaloStyle}">
                    <ui:MaterialIconView
                        IconName="{TemplateBinding IconName}"
                        IconSize="32"
                        IconColor="{DynamicResource Primary}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Border>
                <Label
                    IsVisible="{TemplateBinding HasTitle}"
                    Text="{TemplateBinding TitleText}"
                    Style="{StaticResource SectionTitleStyle}"
                    HorizontalTextAlignment="Center" />
                <Label
                    Text="{TemplateBinding BodyText}"
                    Style="{StaticResource BodyStyle}"
                    HorizontalTextAlignment="Center" />
                <ui:ButtonView
                    IsVisible="{TemplateBinding HasAction}"
                    IsCompact="True"
                    BodyText="{TemplateBinding ActionText}"
                    TapCommand="{TemplateBinding ActionCommand}" />
            </VerticalStackLayout>
        </ControlTemplate>
    </ContentView.ControlTemplate>

</ContentView>
