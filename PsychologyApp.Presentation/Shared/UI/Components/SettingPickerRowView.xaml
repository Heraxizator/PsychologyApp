<?xml version="1.0" encoding="utf-8" ?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

             x:Class="PsychologyApp.Presentation.Shared.UI.Components.SettingPickerRowView"

             x:Name="Root">



    <Grid HeightRequest="50" ColumnSpacing="0">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="*" />

            <ColumnDefinition Width="Auto" />

        </Grid.ColumnDefinitions>

        <Label

            x:Name="SettingLabel"

            Grid.Column="0"

            Text="{Binding LabelText, Source={x:Reference Root}}"

            FontSize="15"

            VerticalOptions="Center"

            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />

        <Picker

            x:Name="SettingPicker"

            Grid.Column="1"

            WidthRequest="125"

            FontSize="15"

            Title="{Binding PickerTitle, Source={x:Reference Root}}"

            TitleColor="{DynamicResource Primary}"

            TextColor="{DynamicResource Secondary}"

            BackgroundColor="Transparent"

            HorizontalOptions="End"

            HorizontalTextAlignment="Start"

            ItemsSource="{Binding ItemsSource, Source={x:Reference Root}}"

            SelectedIndexChanged="OnPickerSelectedIndexChanged" />

    </Grid>



</ContentView>


