<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             x:Class="MobileHelperMaui.Views.ProfilePages.UserPage"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             Title="Профиль">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Параметры" Command="{Binding OpenOptionsCommand}"/>
    </ContentPage.ToolbarItems>
    
    <ContentPage.Content>

        <StackLayout Margin="0, 15, 0, 15">

            <StackLayout
                Margin="25, 10, 25, 25"
                Orientation="Horizontal">

                <Label
                    Margin="0, 0, 0, 0"
                    VerticalOptions="CenterAndExpand"
                    Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                    TextColor="{StaticResource Primary}">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                    </Label.GestureRecognizers>

                </Label>

                <Label
                    Text="Профиль пользователя"
                    HorizontalOptions="CenterAndExpand"
                    VerticalOptions="CenterAndExpand"
                    TextColor="Black"
                    FontSize="19"/>

                <Label
                    Text="{mi:Material Icon=MoreHoriz, IconSize=25}"
                    VerticalOptions="CenterAndExpand"
                    FontSize="20"
                    TextColor="{StaticResource Black}">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenOptionsCommand}"/>
                    </Label.GestureRecognizers>
                    
                </Label>

            </StackLayout>

            <StackLayout>
                <StackLayout Margin="15, 0, 15, 0" Orientation="Horizontal">

                    <Label
                            Text="{mi:Material Icon=AccountCircle, IconSize=50}"
                            Margin="0, 0, 0, 0"
                            TextColor="{StaticResource Gray}"/>


                    <StackLayout Margin="5, 0, 10, 0">
                        <Label 
                        TextColor="{StaticResource Gray}"
                        FontAttributes="Bold"
                        FontSize="19"
                        Padding="0"
                        Margin="0"
                        Text="Пользователь"/>

                        <Label 
                        Text="Стандартный"
                        Padding="0"
                        Margin="0"
                        TextColor="Black"
                        FontSize="16"/>

                    </StackLayout>

                </StackLayout>

            </StackLayout>

            <StackLayout 
            Margin="0, 15, 0, 10"
            HorizontalOptions="Center"
            Orientation="Horizontal">
                <StackLayout Margin="15, 10, 15, 10">
                    <Label 
                    TextColor="Black"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    Text="0"/>
                    <Label 
                    Text="Пройдено техник"
                    FontSize="16"
                    TextColor="Black"/>

                </StackLayout>

                <StackLayout Margin="15, 10, 15, 10">
                    <Label 
                    TextColor="Black"
                    FontSize="16"
                    HorizontalTextAlignment="Center"
                    Text="0"/>
                    <Label 
                    Text="Подписчиков"
                    FontSize="16"
                    TextColor="Black"/>

                </StackLayout>

            </StackLayout>

            <StackLayout Margin="0, 10, 0, 5">
                <Label 
                        Margin="15, 0, 15, 0"
                        Text="Советуем пройти"
                        FontSize="18"
                        TextColor="{StaticResource Gray}"
                        FontAttributes="Bold"
                        HorizontalOptions="Start"/>

                <CollectionView 
                        Margin="15, 0, 0, 0"
                        VerticalOptions="CenterAndExpand"
                        HorizontalScrollBarVisibility="Never"
                        HeightRequest="150"
                        ItemsSource="{Binding Techniques}">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <StackLayout>
                                <Frame
                                    HasShadow="True"
                                        Padding="10"
                                        HeightRequest="130"
                                        WidthRequest="250">

                                    <StackLayout Margin="10, 5, 5, 5">
                                        <Label 
                                            Text="{Binding Title}"
                                            FontAttributes="Bold"
                                            TextColor="{Binding Gray}"
                                            FontSize="18"/>

                                        <Label
                                            HorizontalTextAlignment="Justify"
                                            Text="{Binding Subtitle}"
                                            TextColor="Black"
                                            FontSize="16"/>

                                    </StackLayout>

                                </Frame>
                            </StackLayout>

                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </StackLayout>

            <StackLayout Margin="0, 5, 0, 5">
                <Label 
                        Margin="15, 0, 15, 0"
                        Text="Лучшие цитаты"
                        TextColor="{StaticResource Gray}"
                        FontAttributes="Bold"
                        FontSize="18"/>

                <templates:ProgressbarView
                        HorizontalOptions="CenterAndExpand"
                        VerticalOptions="CenterAndExpand"
                        Margin="15, 75, 15, 0"
                        IsVisible="{Binding IsInit}"
                        IsLoading="True"
                        ProgressText="Поиск цитат">
                    <templates:ProgressbarView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Cancel}"/>
                    </templates:ProgressbarView.GestureRecognizers>
                </templates:ProgressbarView>

                <CollectionView
                        IsVisible="{Binding IsDone}"
                        Margin="15, 0, 15, 0"
                        SelectionMode="None"
                        HeightRequest="300"
                        VerticalScrollBarVisibility="Never"
                        ItemsSource="{Binding Quots}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <StackLayout>
                                <Frame HasShadow="True" Padding="10">

                                    <StackLayout Margin="10, 5, 15, 5">
                                        <Label 
                                                Text="{Binding Author}"
                                                FontAttributes="Bold"
                                                TextColor="{Binding Gray}"
                                                FontSize="18"/>

                                        <Label
                                                HorizontalTextAlignment="Justify"
                                                Text="{Binding Text}"
                                                TextColor="Black"
                                                FontSize="16"/>

                                    </StackLayout>

                                </Frame>
                            </StackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <StackLayout
                            HorizontalOptions="FillAndExpand">

                            <templates:RetryView
                                VerticalOptions="CenterAndExpand"
                                IsVisible="True"
                                FailedText="Цитаты не найдены"
                                RetryText="Попробовать ещё раз?">
                                <templates:RetryView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ReloadCommand}"/>
                                </templates:RetryView.GestureRecognizers>
                            </templates:RetryView>

                        </StackLayout>
                        
                    </CollectionView.EmptyView>
                    
                </CollectionView>

            </StackLayout>

        </StackLayout>

    </ContentPage.Content>
</ContentPage>