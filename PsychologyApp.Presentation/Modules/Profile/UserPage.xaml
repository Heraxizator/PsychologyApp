<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Profile.UserPage"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Profile"
             xmlns:technique="clr-namespace:PsychologyApp.Presentation.Technique"
             xmlns:quotes="clr-namespace:PsychologyApp.Presentation.Modules.Profile"
             x:DataType="vm:UserViewModel"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding OptionsLabel}" Command="{Binding OpenOptionsCommand}" />
    </ContentPage.ToolbarItems>

    <AbsoluteLayout
        VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <StackLayout
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            Margin="0,15,0,15">

            <ui:NavigationBarSimpleView
                Margin="25,0,25,0"
                TitleText="{Binding PageTitle}"
                BackCommand="{Binding Finish}" />

            <StackLayout
                Margin="25,0,25,0"
                HorizontalOptions="FillAndExpand"
                Orientation="Horizontal">

                <StackLayout
                    HorizontalOptions="FillAndExpand"
                    VerticalOptions="CenterAndExpand"
                    Orientation="Horizontal">

                    <Label
                        VerticalOptions="CenterAndExpand"
                        Text="{mi:Material Icon=AccountCircle, IconSize=35}"
                        Margin="15,0,0,0"
                        TextColor="#AAAAAA" />

                    <StackLayout
                        VerticalOptions="CenterAndExpand"
                        Margin="5,0,10,0">
                        <Label
                            Style="{StaticResource SectionTitleStyle}"
                            FontSize="14"
                            Text="{Binding UserLabel}" />
                        <Label
                            Style="{StaticResource BodyStyle}"
                            Text="{Binding StandardUserLabel}" />
                    </StackLayout>

                </StackLayout>

                <Label
                    Text="{Binding OptionsLabel}"
                    Margin="10,0,0,0"
                    VerticalOptions="CenterAndExpand"
                    HorizontalOptions="EndAndExpand"
                    FontFamily="RobotoMedium"
                    TextColor="{StaticResource Primary}"
                    FontSize="14">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenOptionsCommand}" />
                    </Label.GestureRecognizers>
                </Label>

            </StackLayout>

            <StackLayout
                Margin="0,25,15,20"
                HorizontalOptions="Center"
                Orientation="Horizontal">
                <StackLayout Margin="15,10,15,10">
                    <Label
                        Style="{StaticResource SectionTitleStyle}"
                        HorizontalTextAlignment="Center"
                        Text="{Binding TechniquesCompletedCount}" />
                    <Label
                        Style="{StaticResource BodyStyle}"
                        HorizontalTextAlignment="Center"
                        Text="{Binding TechniquesCompletedLabel}" />
                </StackLayout>
                <StackLayout Margin="15,10,15,10">
                    <Label
                        Style="{StaticResource SectionTitleStyle}"
                        HorizontalTextAlignment="Center"
                        Text="0" />
                    <Label
                        Style="{StaticResource BodyStyle}"
                        HorizontalTextAlignment="Center"
                        Text="{Binding FollowersLabel}" />
                </StackLayout>
            </StackLayout>

            <StackLayout Margin="0,10,0,5">
                <Label
                    Margin="15,0,15,5"
                    Text="{Binding RecommendedLabel}"
                    Style="{StaticResource SectionTitleStyle}"
                    HorizontalOptions="Start" />

                <CollectionView
                    Margin="15,0,0,0"
                    VerticalOptions="CenterAndExpand"
                    HorizontalScrollBarVisibility="Never"
                    ItemsSource="{Binding Techniques}">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="technique:TechniqueItem">
                            <Frame HasShadow="True" Padding="10" WidthRequest="250">
                                <ui:TextItemView
                                    TitleText="{Binding Title}"
                                    BodyText="{Binding Subtitle}" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>
            </StackLayout>

            <StackLayout Margin="0,5,0,5">
                <Label
                    Margin="15,0,15,5"
                    Text="{Binding BestQuotesLabel}"
                    Style="{StaticResource SectionTitleStyle}" />

                <ui:ProgressBarView
                    HorizontalOptions="CenterAndExpand"
                    VerticalOptions="CenterAndExpand"
                    Margin="15,75,15,0"
                    IsVisible="{Binding IsInit}"
                    IsLoading="True"
                    ProgressText="{Binding QuotesSearchingText}">
                    <ui:ProgressBarView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Cancel}" />
                    </ui:ProgressBarView.GestureRecognizers>
                </ui:ProgressBarView>

                <CollectionView
                    IsVisible="{Binding IsDone}"
                    Margin="15,0,15,0"
                    SelectionMode="None"
                    VerticalScrollBarVisibility="Never"
                    ItemsSource="{Binding Quotes}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="quotes:QuoteItem">
                            <Frame HasShadow="True" Padding="10">
                                <ui:TextItemView
                                    TitleText="{Binding Author}"
                                    BodyText="{Binding Text}" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <ui:ProgressBarView
                            HorizontalOptions="CenterAndExpand"
                            VerticalOptions="CenterAndExpand"
                            Margin="15,75,15,0"
                            IsLoading="True"
                            ProgressText="{Binding QuotesSearchingText}">
                            <ui:ProgressBarView.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Cancel}" />
                            </ui:ProgressBarView.GestureRecognizers>
                        </ui:ProgressBarView>
                    </CollectionView.EmptyView>

                </CollectionView>

            </StackLayout>

        </StackLayout>

        <ui:RetryView
            AbsoluteLayout.LayoutBounds="0.5,0.5,AutoSize,AutoSize"
            AbsoluteLayout.LayoutFlags="PositionProportional"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding LoadErrorText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding ReloadQuotesCommand}" />
    </AbsoluteLayout>
</ContentPage>
