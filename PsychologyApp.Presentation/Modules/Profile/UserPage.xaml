<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Profile.UserPage"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Profile"
             xmlns:technique="clr-namespace:PsychologyApp.Presentation.Technique"
             xmlns:quotes="clr-namespace:PsychologyApp.Presentation.Modules.Profile"
             x:DataType="vm:UserViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding OptionsLabel}" Command="{Binding OpenOptionsCommand}" />
    </ContentPage.ToolbarItems>

    <AbsoluteLayout
        VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <ScrollView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            VerticalScrollBarVisibility="Never">
            <StackLayout Margin="{StaticResource LayoutPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">

                <ui:NavigationBarSimpleView
                    TitleText="{Binding PageTitle}"
                    BackCommand="{Binding Finish}" />

                <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label
                            Grid.Column="0"
                            VerticalOptions="Center"
                            Text="{mi:Material Icon=AccountCircle, IconSize=40}"
                            TextColor="{StaticResource TextSecondaryLight}" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Style="{StaticResource PageTitleStyle}" Text="{Binding UserLabel}" />
                            <Label Style="{StaticResource BodyStyle}" Text="{Binding StandardUserLabel}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Style="{StaticResource BrandCardStyle}" Margin="0">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label
                                Style="{StaticResource SectionTitleStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding TechniquesCompletedCount}" />
                            <Label
                                Style="{StaticResource BodyStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding TechniquesCompletedLabel}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label
                                Style="{StaticResource SectionTitleStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding TestsCompletedCount}" />
                            <Label
                                Style="{StaticResource BodyStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding TestsCompletedLabel}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" Spacing="4">
                            <Label
                                Style="{StaticResource SectionTitleStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding StreakCount}" />
                            <Label
                                Style="{StaticResource BodyStyle}"
                                HorizontalTextAlignment="Center"
                                Text="{Binding StreakLabel}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Label Text="{Binding RecommendedLabel}" Style="{StaticResource SectionTitleStyle}" />

                <CollectionView
                    HeightRequest="120"
                    HorizontalScrollBarVisibility="Never"
                    ItemsSource="{Binding Techniques}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="technique:TechniqueItem">
                            <Border Style="{StaticResource BrandCardStyle}" WidthRequest="240" Margin="0">
                                <ui:TextItemView
                                    TitleText="{Binding Title}"
                                    BodyText="{Binding Subtitle}" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{Binding BestQuotesLabel}" Style="{StaticResource SectionTitleStyle}" />

                <ui:ProgressBarView
                    IsVisible="{Binding IsInit}"
                    IsLoading="True"
                    ProgressText="{Binding QuotesSearchingText}">
                    <ui:ProgressBarView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Cancel}" />
                    </ui:ProgressBarView.GestureRecognizers>
                </ui:ProgressBarView>

                <CollectionView
                    IsVisible="{Binding IsDone}"
                    SelectionMode="None"
                    VerticalScrollBarVisibility="Never"
                    ItemsSource="{Binding Quotes}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="quotes:QuoteItem">
                            <Border Style="{StaticResource BrandCardStyle}" Margin="0,0,0,8">
                                <ui:TextItemView
                                    TitleText="{Binding Author}"
                                    BodyText="{Binding Text}" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label
                            Margin="0,24,0,0"
                            HorizontalTextAlignment="Center"
                            Style="{StaticResource BodyStyle}"
                            Text="{Binding QuotesEmptyText}" />
                    </CollectionView.EmptyView>
                </CollectionView>

            </StackLayout>
        </ScrollView>

        <ui:RetryView
            AbsoluteLayout.LayoutBounds="0.5,0.5,AutoSize,AutoSize"
            AbsoluteLayout.LayoutFlags="PositionProportional"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding LoadErrorText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding ReloadQuotesCommand}" />
    </AbsoluteLayout>
</ContentPage>
