<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.About.InfoPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.About"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:DataType="vm:InfoViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">
<StackLayout>

        <ui:NavigationBarSimpleView
                BackCommand="{Binding BackCommand}"
                TitleText="{Binding PageTitle}"/>

        <Label
                HorizontalTextAlignment="Justify"
                Text="{Binding AboutBody}"
                FontSize="16"
                TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}"
                Margin="25, 10, 25, 15"/>

        </StackLayout>

</ContentPage>
