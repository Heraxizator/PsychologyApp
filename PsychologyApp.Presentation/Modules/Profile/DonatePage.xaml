<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Modules.Profile.DonatePage"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:DataType="profile:DonateViewModel"
             xmlns:profile="clr-namespace:PsychologyApp.Presentation.Modules.Profile"
             Title="Пожертвования">

    <StackLayout Margin="10, 0, 10, 0">
        <ui:NavigationBarSimpleView
            TitleText="Пожертвования"
            BackCommand="{Binding BackCommand}" />

        <ui:TextBoxView
            HeaderText="Подробнее"
            BodyText="Наш проект существует исключительно на пожертвования. Мы не размещаем рекламу и не оказываем платных услуг. Пожертвования используются на работу программистов и дизайнеров." />

        <ui:ButtonView
            Margin="0, 5, 0, 10"
            BodyText="Пожертвовать"
            TapCommand="{Binding DonateCommand}" />
    </StackLayout>
</ContentPage>
