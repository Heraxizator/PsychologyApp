<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Physics.StartPhysicsPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Physics"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:DataType="vm:StartPhysicsViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding PageTitle}">

    <AbsoluteLayout VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
        <ScrollView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            VerticalScrollBarVisibility="Never">
            <StackLayout Margin="10,0,10,0">
                <ui:ProgressBarView
                    VerticalOptions="CenterAndExpand"
                    IsVisible="{Binding IsInit}"
                    IsLoading="{Binding IsInit}"
                    ProgressText="{Binding LoadingText}"
                    CancelCommand="{Binding Cancel}" />

                <StackLayout IsVisible="{Binding IsDone}">
                    <ui:TextBoxView
                        HeaderText="{Binding ExplanationHeader}"
                        BodyText="{Binding ExplanationBody}" />

                    <ui:TextBoxView
                        HeaderText="{Binding DescriptionHeader}"
                        BodyText="{Binding DescriptionBody}" />

                    <ui:AlgorithmBoxView
                        TitleText="{Binding AlgorithmHeader}"
                        BodySource="{Binding AlgorithmSteps}" />

                    <ui:ButtonView
                        Margin="0,5,0,10"
                        BodyText="{Binding StartButtonText}"
                        TapCommand="{Binding StartCommand}" />
                </StackLayout>
            </StackLayout>
        </ScrollView>

        <ui:RetryView
            AbsoluteLayout.LayoutBounds="0.5,0.5,AutoSize,AutoSize"
            AbsoluteLayout.LayoutFlags="PositionProportional"
            IsVisible="{Binding IsFail}"
            FailedText="{Binding FailedText}"
            RetryText="{Binding RetryText}"
            RetryCommand="{Binding Reload}" />
    </AbsoluteLayout>
</ContentPage>
