<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileHelperMaui.Views.TestPages.FindProblemPage"
             xmlns:vm="clr-namespace:MobileHelper.ViewModels.TestViewModels"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             Title="Детектор">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>
    <ContentPage.Content>
        <ScrollView>
            <StackLayout Margin="0">

                <StackLayout
                    Margin="25, 10, 25, 10"
                    Orientation="Horizontal">

                    <Label
                        Margin="0, 0, 0, 0"
                        VerticalOptions="CenterAndExpand"
                        Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                        TextColor="{StaticResource Primary}">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                        </Label.GestureRecognizers>

                    </Label>

                    <Label
                        Text="Поиск проблемы"
                        HorizontalOptions="CenterAndExpand"
                        VerticalOptions="CenterAndExpand"
                        TextColor="Black"
                        FontSize="19"/>

                </StackLayout>

                <templates:TextBoxView
                    HeaderText="Описание"
                    BodyText="{Binding DescribtionText}"/>

                <Frame Margin="15, 10, 15, 15">
                    <StackLayout Margin="0">
                        <Label
                    Text="Алгоритм"
                    FontSize="18"
                    Margin="5, 0, 0, 10"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <ListView 
                        SelectionMode="None"
                        SeparatorVisibility="None"
                        HasUnevenRows="True"
                        VerticalScrollBarVisibility="Never"
                        ItemsSource="{Binding AlgorithmRows}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Label 
                                    Margin="10, 0, 0, 0"
                                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                                    Text="{Binding Row}"
                                    FontSize="16">
                                        </Label>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </StackLayout>

                </Frame>

                <Frame Margin="15, 10, 15, 15">
                    <StackLayout Margin="0">
                        <Label
                    Text="Замечание"
                    FontSize="18"
                    Margin="5, 0, 0, 10"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <Label
                    Margin="5, 0, 0, 10"
                    Text="{Binding CommentText}"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                    </StackLayout>

                </Frame>

                <Button 
                Margin="10, 15, 10, 15"
                Text="Начать"
                FontSize="15"
                BackgroundColor="{StaticResource Primary}"
                CornerRadius="25"
                WidthRequest="350"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Command="{Binding Continue}"
                HeightRequest="40"/>
            </StackLayout>
        </ScrollView>

    </ContentPage.Content>
</ContentPage>