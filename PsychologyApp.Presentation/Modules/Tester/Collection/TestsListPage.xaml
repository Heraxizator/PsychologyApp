<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileHelperMaui.Views.TestPages.TestsListPage"
             Shell.NavBarIsVisible="True"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Modules.Tester.Collection"
             Title="Детектор">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <AbsoluteLayout 
        VerticalOptions="FillAndExpand" 
        HorizontalOptions="FillAndExpand">
        
        <CollectionView
            AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
            AbsoluteLayout.LayoutFlags="All"
            x:Name="coll_view"
            Margin="20, 20, 15, 5"
            HorizontalOptions="CenterAndExpand"
            VerticalOptions="StartAndExpand"
            VerticalScrollBarVisibility="Never"
            SelectionMode="Single"
            SelectionChanged="CollectionView_SelectionChanged"
            ItemsSource="{Binding TestItemCollection}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TestItem">
                    <StackLayout Padding="0, 0, 0, 15">
                        <Label 
                            Margin="0, 0, 0, 5"
                            FontSize="16"
                            TextColor="Black"
                            Text="{Binding Title}"/>
                        <Label
                            FontSize="15"
                            TextColor="{StaticResource Gray}"
                            Text="{Binding Subtitle}"/>

                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </AbsoluteLayout>
</ContentPage>