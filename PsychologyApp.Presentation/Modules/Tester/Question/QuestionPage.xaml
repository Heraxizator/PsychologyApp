<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Modules.Tester.QuestionPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Modules.Tester"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons">

    <AbsoluteLayout 
        HorizontalOptions="FillAndExpand" 
        VerticalOptions="FillAndExpand">

    <CollectionView
            AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
            AbsoluteLayout.LayoutFlags="All"
            Margin="10"
            x:DataType="vm:QuestionViewModel"
            ItemsSource="{Binding Questions}">

        <CollectionView.Header>

            <StackLayout
                Margin="25, 10, 25, 10"
                Orientation="Horizontal">

                <Label
                    Margin="0, 0, 0, 0"
                    VerticalOptions="CenterAndExpand"
                    Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                    TextColor="{StaticResource Primary}">

                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                    </Label.GestureRecognizers>

                </Label>

                <Label
                    Text="Опросник"
                    HorizontalOptions="CenterAndExpand"
                    VerticalOptions="CenterAndExpand"
                    TextColor="Black"
                    FontSize="19"/>

            </StackLayout>

        </CollectionView.Header>
        
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame 
                        x:DataType="vm:Question"
                        HasShadow="True">

                    <StackLayout>

                        <Label
                                Margin="0, 0, 0, 10"
                                TextColor="{StaticResource Primary}"
                                FontSize="16">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Вопрос "/>
                                    <Span Text="{Binding Number}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <CollectionView
                                x:DataType="vm:Question"
                                ItemsSource="{Binding Answers}">

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:Answer">

                                    <StackLayout 
                                        HorizontalOptions="FillAndExpand"
                                            Orientation="Horizontal">

                                        <CheckBox 
                                                VerticalOptions="Center"
                                                IsChecked="{Binding Selected}"/>

                                        <Label 
                                                VerticalOptions="Center"
                                                HorizontalOptions="FillAndExpand"
                                                HorizontalTextAlignment="Justify"
                                                Text="{Binding Text}"/>

                                    </StackLayout>

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </StackLayout>

                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.Footer>

            <templates:ButtonView
                Margin="15, 5, 15, 20"
                BodyText="Завершить">

                <templates:ButtonView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ConfirmCommand}"/>
                </templates:ButtonView.GestureRecognizers>

            </templates:ButtonView>

        </CollectionView.Footer>
        
    </CollectionView>

    </AbsoluteLayout>

</ContentPage>