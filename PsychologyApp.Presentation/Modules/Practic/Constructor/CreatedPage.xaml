<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="MobileHelperMaui.Views.TechniquePages.ConstructorPages.CreatedPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Technique.Constructor"
             Title="Техника">

    <ContentPage.BindingContext>
        <vm:CreatedViewModel/>
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Изменить" Command="{Binding Edit}" />
        <ToolbarItem Text="Удалить" Command="{Binding Remove}" />
    </ContentPage.ToolbarItems>

    <StackLayout>

        <StackLayout
            Margin="25, 10, 25, 10"
            Orientation="Horizontal">

            <Label
                Margin="0, 0, 0, 0"
                VerticalOptions="CenterAndExpand"
                Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                TextColor="{StaticResource Primary}">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                </Label.GestureRecognizers>

            </Label>

            <Label
                Text="Своя техника"
                HorizontalOptions="CenterAndExpand"
                VerticalOptions="CenterAndExpand"
                TextColor="Black"
                FontSize="19"/>

            <Label
                Text="{mi:Material Icon=Edit, IconSize=20}"
                Margin="0, 0, 15, 0"
                TextColor="{StaticResource Primary}"
                FontSize="17">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Edit}"/>
                </Label.GestureRecognizers>
                
            </Label>

            <Label
                Text="{mi:Material Icon=DeleteOutline, IconSize=20}"
                TextColor="{StaticResource Primary}"
                FontSize="17">

                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Remove}"/>
                </Label.GestureRecognizers>

            </Label>

        </StackLayout>

        <StackLayout Margin="0">
            <Frame HasShadow="True" MinimumHeightRequest="500" Margin="15, 15, 15, 15">
                <StackLayout Margin="5">
                    <Label
                    Text="Алгоритм"
                    FontSize="18"
                    Margin="10, 5, 5, 15"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                    <ListView 
                    Margin="0, 0, 0, 5"
                    ItemsSource="{Binding Elements}"
                    SeparatorVisibility="None"
                    SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <ViewCell>
                                    <Label 
                                    Margin="15, 0, 0, 10"
                                    Text="{Binding Text}"
                                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                                    FontSize="16"/>
                                </ViewCell>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackLayout>

            </Frame>

            <Button 
                Margin="10, 15, 10, 15"
                Text="Завершить"
                FontSize="15"
                TextColor="White"
                BackgroundColor="{StaticResource Primary}"
                CornerRadius="25"
                WidthRequest="350"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Command="{Binding Finish}"
                HeightRequest="40"/>
        </StackLayout>
    </StackLayout>
</ContentPage>