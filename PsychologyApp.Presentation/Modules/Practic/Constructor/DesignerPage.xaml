<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="MobileHelperMaui.Views.TechniquePages.ConstructorPages.DesignerPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Modules.Practic.Constructor"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             Title="Техника">
    
    <ContentPage.BindingContext>
        <vm:DesignerViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>

        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout>

        <ScrollView Margin="0, 0, 0, 0" VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never">
            <StackLayout Margin="0">

                <StackLayout
                    Margin="25, 10, 25, 10"
                    Orientation="Horizontal">

                    <Label
                        Margin="0, 0, 0, 0"
                        VerticalOptions="CenterAndExpand"
                        Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                        TextColor="{StaticResource Primary}">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                        </Label.GestureRecognizers>

                    </Label>

                    <Label
                        Text="Создание техники"
                        HorizontalOptions="CenterAndExpand"
                        VerticalOptions="CenterAndExpand"
                        TextColor="Black"
                        FontSize="19"/>

                </StackLayout>

                <Frame HasShadow="True" Margin="15, 15, 15, 15">
                    <StackLayout Margin="0">
                        <Label
                    Text="Описание"
                    FontSize="18"
                    Margin="10, 5, 5, 15"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <Frame BackgroundColor="{AppThemeBinding Light=white, Dark=#444444}" Margin="5, 5, 5, 5" Padding="10" BorderColor="{StaticResource Accent}" CornerRadius="25">
                            <StackLayout>
                                <Label TextColor="{AppThemeBinding Light=black, Dark=white}" Padding="0" Text="Название" FontSize="15"/>
                                <Entry
                                PlaceholderColor="{StaticResource Accent}"
                                Placeholder="Крутилка Славинского"
                                FontSize="15"
                                Text="{Binding Name}"
                                TextColor="{AppThemeBinding Light=black, Dark=white}"
                                VerticalTextAlignment="Center"/>
                            </StackLayout>

                        </Frame>

                        <Frame BackgroundColor="{AppThemeBinding Light=white, Dark=#444444}" Margin="5, 5, 5, 5" Padding="10" BorderColor="{StaticResource Accent}" CornerRadius="25">
                            <StackLayout>
                                <Label TextColor="{AppThemeBinding Light=black, Dark=white}" Padding="0" Text="Описание" FontSize="15"/>
                                <Entry
                                PlaceholderColor="{StaticResource Accent}"
                                Placeholder="Метод мгновенной нейтрализации..."
                                FontSize="15"
                                Text="{Binding Description}"
                                TextColor="{AppThemeBinding Light=black, Dark=white}"
                                VerticalTextAlignment="Center"/>
                            </StackLayout>

                        </Frame>

                        <Frame BackgroundColor="{AppThemeBinding Light=white, Dark=#444444}" Margin="5, 5, 5, 5" Padding="10" BorderColor="{StaticResource Accent}" CornerRadius="25">
                            <StackLayout>
                                <Label TextColor="{AppThemeBinding Light=black, Dark=white}" Padding="0" Text="Тема" FontSize="15"/>
                                <Entry
                                PlaceholderColor="{StaticResource Accent}"
                                Placeholder="Эпизоды"
                                FontSize="15"
                                Text="{Binding Theme}"
                                TextColor="{AppThemeBinding Light=black, Dark=white}"
                                VerticalTextAlignment="Center"/>
                            </StackLayout>

                        </Frame>

                        <Frame BackgroundColor="{AppThemeBinding Light=white, Dark=#444444}" Margin="5, 5, 5, 15" Padding="10" BorderColor="{StaticResource Accent}" CornerRadius="25">
                            <StackLayout>
                                <Label TextColor="{AppThemeBinding Light=black, Dark=white}" Padding="0" Text="Автор" FontSize="15"/>
                                <Entry
                                PlaceholderColor="{StaticResource Accent}"
                                Placeholder="Живорад Славинский"
                                FontSize="15"
                                Text="{Binding Author}"
                                TextColor="{AppThemeBinding Light=black, Dark=white}"
                                VerticalTextAlignment="Center"/>
                            </StackLayout>

                        </Frame>

                    </StackLayout>

                </Frame>

                <Frame HasShadow="True" Margin="15, 10, 15, 15">
                    <StackLayout>
                        <Label
                        Text="Алгоритм"
                        FontSize="18"
                        Margin="5, 0, 0, 10"
                        TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <Frame BackgroundColor="{AppThemeBinding Light=white, Dark=#444444}" Margin="10, 5, 10, 15" Padding="10" BorderColor="{StaticResource Accent}" CornerRadius="25">
                            <StackLayout>
                                <Label TextColor="{AppThemeBinding Light=black, Dark=white}" Padding="0" Text="Список действий" FontSize="15"/>

                                <Editor 
                                HeightRequest="160"
                                TextColor="{AppThemeBinding Light=black, Dark=white}"
                                Text="{Binding Algorithm}"
                                MaxLength="300"/>


                            </StackLayout>

                        </Frame>
                    </StackLayout>

                </Frame>

                <Frame HasShadow="True" Margin="15, 10, 15, 15">
                    <StackLayout>
                        <Label
                        Text="Изображение"
                        FontSize="18"
                        Margin="5, 0, 0, 15"
                        TextColor="{AppThemeBinding Light=black, Dark=white}"/>


                        <Image   
                        WidthRequest="150"
                        HeightRequest="150"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Source="{Binding Path}"/>

                        <!--
                    <Label 
                        Text="Нет фото"
                        TextColor="{AppThemeBinding Light=gray, Dark=white}"
                        FontSize="17"
                        Padding="40"
                        VerticalOptions="Center"
                        HorizontalOptions="Center"/>
                    -->

                        <Button 
                        Margin="10, 20, 10, 10"
                        Text="Галерея"
                        FontSize="15"
                        TextColor="White"
                        Command="{Binding OpenGallery}"
                        BackgroundColor="{StaticResource Accent}"
                        CornerRadius="25"
                        WidthRequest="300"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>

                        <Button 
                        Margin="10, 2, 10, 15"
                        Text="Камера"
                        FontSize="15"
                        TextColor="White"
                        Command="{Binding OpenCamera}"
                        BackgroundColor="{StaticResource Accent}"
                        CornerRadius="25"
                        WidthRequest="300"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"/>

                    </StackLayout>

                </Frame>

                <Button 
                Margin="10, 15, 10, 15"
                Text="{Binding Aim}"
                FontSize="15"
                BackgroundColor="{StaticResource Primary}"
                Command="{Binding ExecuteTechnique}"
                CornerRadius="25"
                WidthRequest="350"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                HeightRequest="40"/>


            </StackLayout>
        </ScrollView>

    </StackLayout>
</ContentPage>