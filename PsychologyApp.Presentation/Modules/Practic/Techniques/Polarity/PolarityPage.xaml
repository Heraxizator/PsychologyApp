<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileHelperMaui.Views.TechniquePages.PolarityPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Technique"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             Title="Техника">
    
    <ContentPage.BindingContext>
        <vm:PolarityViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Теория" Command="{Binding Theory}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <ScrollView x:Name="Scroll" VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never">
            <StackLayout Margin="0">

                <StackLayout
                    Margin="25, 10, 25, 10"
                    Orientation="Horizontal">

                    <Label
                        Margin="0, 0, 0, 0"
                        VerticalOptions="CenterAndExpand"
                        Text="{mi:Material Icon=KeyboardArrowLeft, IconSize=25}"
                        TextColor="{StaticResource Primary}">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                        </Label.GestureRecognizers>

                    </Label>

                    <Label
                        Text="Полярности"
                        HorizontalOptions="CenterAndExpand"
                        VerticalOptions="CenterAndExpand"
                        TextColor="Black"
                        FontSize="19"/>

                    <Label
                        Text="Теория"
                        Margin="10, 0, 0, 0"
                        VerticalOptions="CenterAndExpand"
                        TextColor="{StaticResource Primary}"
                        FontSize="15">

                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Theory}"/>
                        </Label.GestureRecognizers>

                    </Label>

                </StackLayout>

                <Frame x:Name="Algorithm" Margin="15, 15, 15, 15">
                    <StackLayout Margin="5">
                        <Label
                    Text="Алгоритм"
                    FontSize="18"
                    Margin="10, 5, 5, 15"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <Label 
                    Margin="15, 0, 0, 10"
                    Text="1. Найти то, что важно"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                        <Label 
                    Margin="15, 0, 5, 10"
                    Text="2. Найти то, что противоположно"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                        <Label 
                    Margin="15, 0, 0, 15"
                    Text="3. Повторить п.1 и п.2 много раз"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                    </StackLayout>

                </Frame>

                <Frame Margin="15, 10, 15, 15">
                    <StackLayout Margin="0, 0, 0, 0">
                        <Label
                    Text="Форма"
                    FontSize="18"
                    Margin="5, 0, 5, 5"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <templates:TextEntryView
                            TitleText="Первая полярность"
                            PlaceholderText="Невроз"
                            BodyText="{Binding Negative}"/>

                        <templates:TextEntryView
                            TitleText="Вторая полярность"
                            PlaceholderText="Покой"
                            BodyText="{Binding Positive}"/>


                        <templates:ButtonView
                            Margin="0, 5, 0, 0"
                            BodyText="Добавить">

                            <templates:ButtonView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_1" Command="{Binding Add}"/>
                            </templates:ButtonView.GestureRecognizers>

                        </templates:ButtonView>

                    </StackLayout>

                </Frame>

                <CollectionView
                x:Name="Polarities"
                IsVisible="{Binding IsFull}"
                Margin="0, 0, 0, 5"
                SelectionMode="Single"
                    SelectionChanged="Polarities_SelectionChanged"
                ItemsSource="{Binding polarities}"
                VerticalScrollBarVisibility="Never"
                HorizontalScrollBarVisibility="Never">

                    <CollectionView.ItemTemplate>

                        <DataTemplate>


                            <Frame Padding="10">

                                <StackLayout>
                                    <StackLayout Orientation="Horizontal">
                                        <Label 
                                               Text="{Binding Id}"
                                               Margin="5, 0, 0, 0"
                                               FontSize="14"
                                               TextColor="Black"
                                               HorizontalOptions="Start" />

                                        <Label
                                                TextColor="{StaticResource Gray}"
                                                HorizontalOptions="EndAndExpand"
                                                Text="{mi:Material Icon=Close, IconSize=25}">

                                        </Label>

                                    </StackLayout>

                                    <StackLayout
                                            Margin="0, 10, 0, 0"
                                            Orientation="Horizontal">
                                        <Label 
                                                Margin="20, 0, 0, 0"
                                                WidthRequest="150"
                                                Text="{Binding Positive}"
                                                TextColor="Black"
                                                HorizontalOptions="Start"
                                                FontSize="19"/>
                                        <Image 
                                                Source="minus.png"
                                                Opacity="0.6"
                                                WidthRequest="40"
                                                HeightRequest="40"
                                                HorizontalOptions="CenterAndExpand"
                                                />
                                        <Label 
                                                Margin="0, 0, 20, 0"
                                                Text="{Binding Negative}"
                                                WidthRequest="150"
                                                HorizontalTextAlignment="End"
                                                TextColor="Black"
                                                FontSize="19"/>

                                    </StackLayout>
                                </StackLayout>

                            </Frame>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

            </StackLayout>
        </ScrollView>

    </ContentPage.Content>
</ContentPage>