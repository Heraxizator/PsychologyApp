<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileHelperMaui.Views.TechniquePages.ResizePage"
             xmlns:templates="clr-namespace:PsychologyApp.Presentation.Templates"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Modules.Practic.Techniques.Resize"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             Title="Техника">

    <ContentPage.BindingContext>
        <vm:ResizeViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="Accent">#96d1ff</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Теория" Command="{Binding Theory}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <ScrollView>
            <StackLayout Margin="0">

                <templates:NavigationBarExtendedView
                    TitleText="Уменьши Это"
                    BackCommand="{Binding Finish}"
                    ExtensionText="Теория"
                    ExtensionCommand="{Binding Theory}"/>

                <Frame Margin="15, 15, 15, 15">
                    <StackLayout Margin="5">
                        <Label
                    Text="Алгоритм"
                    FontSize="18"
                    Margin="10, 5, 5, 15"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"/>

                        <Label 
                    Margin="15, 0, 0, 10"
                    Text="1. Найти то, что вас беспокоит"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                        <Label 
                    Margin="15, 0, 0, 15"
                    Text="2. Представить как объект"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                        <Label 
                    Margin="15, 0, 0, 15"
                    Text="3. Уменьшить и отдалить"
                    TextColor="{AppThemeBinding Light=black, Dark=white}"
                    FontSize="16"/>

                    </StackLayout>

                </Frame>

                <templates:ButtonView
                Margin="15, 5, 15, 20"
                BodyText="Завершить">

                    <templates:ButtonView.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Finish}"/>
                    </templates:ButtonView.GestureRecognizers>

                </templates:ButtonView>

            </StackLayout>
        </ScrollView>

    </ContentPage.Content>

</ContentPage>