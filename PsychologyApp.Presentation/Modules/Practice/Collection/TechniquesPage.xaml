<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.TechniquesPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.Technique.Main"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:technique="clr-namespace:PsychologyApp.Presentation.Technique"
             x:DataType="vm:TechniquesViewModel"
             Shell.NavBarIsVisible="True"
             Title="{Binding PageTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ProfileToolbarText}" Command="{Binding OpenProfileCommand}" />
    </ContentPage.ToolbarItems>

    <AbsoluteLayout
        VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <CollectionView
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            Margin="{StaticResource LayoutPageMarginThickness}"
            ItemsSource="{Binding Techniques}"
            SelectionMode="Single"
            VerticalScrollBarVisibility="Never"
            HorizontalScrollBarVisibility="Never">

            <CollectionView.Header>
                <StackLayout Spacing="{StaticResource LayoutSpacing}">
                    <Label Text="{Binding TodayForYouLabel}" Style="{StaticResource SectionTitleStyle}" />
                    <Border Style="{StaticResource BrandCardStyle}" Margin="0" BackgroundColor="{StaticResource PrimaryTint}">
                        <StackLayout Spacing="8">
                            <Label Text="{Binding TodayRecommendedLabel}" Style="{StaticResource BodyStyle}" />
                            <Label Text="{Binding TodayTechniqueTitle}" Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="{Binding StreakDisplay}" TextColor="{StaticResource Primary}" FontFamily="{StaticResource MediumFontFamily}" />
                            <ui:ButtonView
                                BodyText="{Binding TodayStartPracticeText}"
                                TapCommand="{Binding StartTodayPracticeCommand}" />
                            <Label Text="{Binding TodayMoodQuestion}" Style="{StaticResource BodyStyle}" />
                            <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8">
                                <Button Text="😞" Command="{Binding RecordMood1Command}" BackgroundColor="Transparent" />
                                <Button Text="😐" Command="{Binding RecordMood2Command}" BackgroundColor="Transparent" />
                                <Button Text="🙂" Command="{Binding RecordMood3Command}" BackgroundColor="Transparent" />
                                <Button Text="😊" Command="{Binding RecordMood4Command}" BackgroundColor="Transparent" />
                                <Button Text="🤩" Command="{Binding RecordMood5Command}" BackgroundColor="Transparent" />
                            </StackLayout>
                        </StackLayout>
                    </Border>
                    <StackLayout Orientation="Horizontal">
                        <Label
                            Text="{Binding MyTechniquesLabel}"
                            Style="{StaticResource SectionTitleStyle}"
                            HorizontalOptions="StartAndExpand"
                            VerticalOptions="Center" />
                        <ui:ButtonView
                            IsCompact="True"
                            VerticalOptions="Center"
                            BodyText="{Binding CreateButtonText}"
                            TapCommand="{Binding ConstructorTapped}" />
                    </StackLayout>
                </StackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="technique:TechniqueItem">
                    <ui:TechniqueListCardView
                        Number="{Binding Number}"
                        Date="{Binding Date}"
                        Image="{Binding Image}"
                        Title="{Binding Title}"
                        Subtitle="{Binding Subtitle}"
                        Theme="{Binding Theme}"
                        Author="{Binding Author}"
                        Active="{Binding Active}"
                        TapCommand="{Binding TapCommand}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <StackLayout Padding="{StaticResource LayoutEmptyPaddingThickness}" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label HorizontalTextAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="{Binding PracticeEmptyTitle}" />
                    <Label HorizontalTextAlignment="Center" Style="{StaticResource BodyStyle}" Text="{Binding PracticeEmptyBody}" />
                </StackLayout>
            </CollectionView.EmptyView>

        </CollectionView>

    </AbsoluteLayout>
</ContentPage>
