<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.TechniquePages.TechniqueSessionPage"
             xmlns:techniques="clr-namespace:PsychologyApp.Presentation.Modules.Practice.Techniques"
             xmlns:controls="clr-namespace:PsychologyApp.Presentation.Controls"
             Title="{Binding TechniquePageTitle}">

    <ContentPage.Behaviors>
        <techniques:TechniqueSessionBehavior />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding TheoryToolbarText}" Command="{Binding Theory}" />
    </ContentPage.ToolbarItems>

    <controls:TechniquePageShell
        x:Name="SessionShell"
        TitleText="{Binding PageName}"
        Algorithm="{Binding Algorithm}"
        BackCommand="{Binding Finish}"
        TheoryCommand="{Binding Theory}"
        FinishCommand="{Binding Finish}" />
</ContentPage>
