<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.TechniquePages.TheoryPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.TechniqueViewModels"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             x:DataType="vm:TheoryViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <ScrollView VerticalScrollBarVisibility="Never">
        <StackLayout Margin="20,0,20,20" Spacing="20">
            <ui:NavigationBarSimpleView
                TitleText="{Binding PageTitle}"
                BackText="{Binding BackText}"
                BackCommand="{Binding Finish}" />
            <ui:TextBoxView
                HeaderText="{Binding PageTitle}"
                BodyText="{Binding Text}" />
        </StackLayout>
    </ScrollView>
</ContentPage>
