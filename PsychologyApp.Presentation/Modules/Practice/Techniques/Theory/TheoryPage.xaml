<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.TechniquePages.TheoryPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.TechniqueViewModels"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             Title="Теория">
<ContentPage.Content>

        <StackLayout>

            <ui:NavigationBarSimpleView
                TitleText="Теория"
                BackText="Назад"
                BackCommand="{Binding Finish}"/>

            <Label
                HorizontalTextAlignment="Justify"
                Text="{Binding Text}"
                FontSize="18"
                TextColor="{AppThemeBinding Light=black, Dark=white}"
                Margin="15, 5, 15, 10"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>