<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="PsychologyApp.Presentation.Views.TechniquePages.ConstructorPages.DesignerPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Practice.Constructor"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             Title="Техника">
<StackLayout>

        <ScrollView 
            VerticalOptions="FillAndExpand" 
            VerticalScrollBarVisibility="Never"
            HorizontalScrollBarVisibility="Never">
            <StackLayout Margin="10, 0, 10, 0">

                <ui:NavigationBarSimpleView
                    TitleText="Создание техники"
                    BackText="Назад"
                    BackCommand="{Binding Finish}"/>

                <Frame HasShadow="True" Margin="10, 15, 10, 15">
                    <StackLayout Margin="0">
                        <Label
                            Text="Описание"
                            FontFamily="RobotoMedium"
                            FontSize="16"
                            TextColor="{StaticResource TextPrimary}"/>

                        <ui:TextEntryView
                            Margin="0, 5, 0, 0"
                            TitleText="Название"
                            PlaceholderText="Крутилка Славинского"
                            BodyText="{Binding Name}"/>

                        <ui:TextEntryView
                            TitleText="Описание"
                            PlaceholderText="Метод мгновенной нейтрализации..."
                            BodyText="{Binding Description}"/>

                        <ui:TextEntryView
                            TitleText="Тема"
                            PlaceholderText="Эпизоды"
                            BodyText="{Binding Theme}"/>

                        <ui:TextEntryView
                            TitleText="Автор"
                            PlaceholderText="Живорад Славинский"
                            BodyText="{Binding Author}"/>

                    </StackLayout>

                </Frame>

                <Frame HasShadow="True" Margin="10, 10, 10, 15">
                    <StackLayout>
                        <Label
                            Text="Алгоритм"
                            FontFamily="RobotoMedium"
                            FontSize="16"
                            TextColor="{StaticResource TextPrimary}"/>

                        <ui:TextEntryView
                            Margin="0, 5, 0, 0"
                            TitleText="Список действий"
                            BodyText="{Binding Actions}"/>

                    </StackLayout>

                </Frame>

                <ui:ButtonView
                    Margin="0, 5, 0, 10"
                    BodyText="Сохранить"
                    TapCommand="{Binding ExecuteTechnique}" />

            </StackLayout>
        </ScrollView>

    </StackLayout>
</ContentPage>