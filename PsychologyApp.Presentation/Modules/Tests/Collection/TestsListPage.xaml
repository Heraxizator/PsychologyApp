<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Tests.TestsListPage"
             Shell.NavBarIsVisible="True"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Tests"
             x:DataType="vm:TestsListViewModel"
             Title="{Binding PageTitle}">
<AbsoluteLayout 
        VerticalOptions="FillAndExpand" 
        HorizontalOptions="FillAndExpand">
        
        <CollectionView
            AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
            AbsoluteLayout.LayoutFlags="All"
            x:Name="TestsCollectionView"
            Margin="20, 20, 15, 5"
            HorizontalOptions="CenterAndExpand"
            VerticalOptions="StartAndExpand"
            VerticalScrollBarVisibility="Never"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedTestItem, Mode=TwoWay}"
            ItemsSource="{Binding TestItemCollection}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:TestItem">
                    <ui:TextItemView
                        Padding="0, 0, 0, 15"
                        TitleText="{Binding Title}"
                        BodyText="{Binding Subtitle}"/>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </AbsoluteLayout>
</ContentPage>