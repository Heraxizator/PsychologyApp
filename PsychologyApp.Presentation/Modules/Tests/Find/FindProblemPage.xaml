<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Tests.FindProblemPage"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Tests"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:behaviors="clr-namespace:PsychologyApp.Presentation.Infrastructure.Behaviors"
             x:DataType="vm:FindProblemViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">

    <StackLayout VerticalOptions="FillAndExpand">
        <StackLayout.Behaviors>
            <behaviors:StaggerChildrenBehavior />
        </StackLayout.Behaviors>
        <ui:NavigationBarSimpleView
            TitleText="{Binding PageTitle}"
            BackCommand="{Binding BackCommand}" />

        <ScrollView VerticalOptions="FillAndExpand" VerticalScrollBarVisibility="Never">
            <StackLayout Margin="20,0,20,20" Spacing="20">
                <ui:TextBoxView
                    HeaderText="{Binding DescriptionHeader}"
                    BodyText="{Binding DescriptionText}" />

                <ui:AlgorithmBoxView TitleText="{Binding AlgorithmHeader}">
                    <ui:AlgorithmBoxView.ItemsSource>
                        <Binding Path="AlgorithmRows" />
                    </ui:AlgorithmBoxView.ItemsSource>
                    <ui:AlgorithmBoxView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AlgorithmRow">
                            <Label Text="{Binding Text}" Style="{StaticResource BodyStyle}" Margin="0,0,0,3">
                                <Label.Behaviors>
                                    <behaviors:ListItemRevealBehavior />
                                </Label.Behaviors>
                            </Label>
                        </DataTemplate>
                    </ui:AlgorithmBoxView.ItemTemplate>
                </ui:AlgorithmBoxView>

                <ui:TextBoxView
                    HeaderText="{Binding NoteHeader}"
                    BodyText="{Binding CommentText}" />

                <ui:ButtonView
                    Margin="0,5,0,0"
                    BodyText="{Binding StartButtonText}"
                    TapCommand="{Binding Continue}" />
            </StackLayout>
        </ScrollView>
    </StackLayout>
</ContentPage>
