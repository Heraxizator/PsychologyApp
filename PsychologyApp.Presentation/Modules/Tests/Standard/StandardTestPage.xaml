<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PsychologyApp.Presentation.Views.Tests.StandardTestPage"
             xmlns:ui="clr-namespace:PsychologyApp.Presentation.UI.Components"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:vm="clr-namespace:PsychologyApp.Presentation.ViewModels.Tests"
             x:DataType="vm:StandardTestViewModel"
             Shell.NavBarIsVisible="False"
             Title="{Binding PageTitle}">
<StackLayout VerticalOptions="FillAndExpand">

        <ui:NavigationBarSimpleView
            TitleText="{Binding PageTitle}"
            BackCommand="{Binding Finish}" />

        <ScrollView VerticalOptions="FillAndExpand" VerticalScrollBarVisibility="Never">
            <StackLayout>
                <StackLayout IsVisible="{Binding IsStart}">
                    <StackLayout Margin="{StaticResource LayoutPageMarginThickness}">
                        <Label
                            HorizontalTextAlignment="Center"
                            Text="{Binding ColorInstruction}"
                            Style="{StaticResource SectionTitleStyle}" />
                    </StackLayout>

                    <StackLayout Margin="0, 5, 0, 15">

                        <BoxView 
                    Margin="30, 0, 30, 5"
                    HeightRequest="3"
                    Color="{StaticResource Primary}"/>

                        <FlexLayout JustifyContent="Center">

                            <BoxView 
                        IsVisible="{Binding IsRed}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="1"
                        Grid.Row="0"
                        Color="Red"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding RedHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <BoxView
                        IsVisible="{Binding IsBrown}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="2"
                        Grid.Row="1"
                        Color="Brown"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BrownHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <BoxView 
                        IsVisible="{Binding IsYellow}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="1"
                        Grid.Row="1"
                        Color="Yellow"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding YellowHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                        </FlexLayout>

                        <FlexLayout Margin="10, 0, 10, 0" JustifyContent="Center">

                            <BoxView 
                        IsVisible="{Binding IsGreen}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Color="Green"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GreenHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <BoxView 
                        IsVisible="{Binding IsBlue}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="2"
                        Grid.Row="0"
                        Color="Blue"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BlueHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <BoxView
                        IsVisible="{Binding IsPurple}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="0"
                        Grid.Row="1"
                        Color="Purple"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PurpleHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                        </FlexLayout>

                        <FlexLayout JustifyContent="Center">

                            <BoxView 
                        IsVisible="{Binding IsGray}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Color="Gray"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GrayHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                            <BoxView
                        IsVisible="{Binding IsBlack}"
                        Margin="10"
                        WidthRequest="100"
                        HeightRequest="100"
                        CornerRadius="15"
                        Grid.Column="0"
                        Grid.Row="1"
                        Color="Black"
                        Opacity="0.9">
                                <BoxView.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BlackHandler}"/>
                                </BoxView.GestureRecognizers>
                            </BoxView>

                        </FlexLayout>

                        <BoxView 
                        Margin="30, 10, 30, 0"
                        HeightRequest="3"
                        Color="{StaticResource Primary}"/>

                    </StackLayout>

                    <ui:TextBoxView
                        Margin="0, -10, 0, 0"
                        HeaderText="{Binding MoreInfoHeader}"
                        BodyText="{Binding MoreInfoBody}"/>

                </StackLayout>

                <StackLayout 
                IsVisible="{Binding IsFinish}">

                    <StackLayout Margin="{StaticResource LayoutPageMarginThickness}" Spacing="{StaticResource LayoutSpacing}">

                        <CollectionView
                            SelectionMode="None"
                            VerticalScrollBarVisibility="Never"
                            ItemsSource="{Binding ResultItems}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ResultItem">
                                    <Border Style="{StaticResource BrandCardStyle}">
                                        <VerticalStackLayout Spacing="8">
                                            <Label LineBreakMode="WordWrap">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span
                                                            Text="{Binding PropertyName}"
                                                            FontFamily="{StaticResource SemiBoldFontFamily}"
                                                            FontSize="{StaticResource SectionTitleFontSize}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                                        <Span
                                                            Text=": "
                                                            FontFamily="{StaticResource BodyFontFamily}"
                                                            FontSize="{StaticResource BodyFontSize}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                                        <Span
                                                            Text="{Binding PropertyValue}"
                                                            FontFamily="{StaticResource SemiBoldFontFamily}"
                                                            FontSize="{StaticResource SectionTitleFontSize}"
                                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label
                                                Text="{Binding PropertyText}"
                                                HorizontalTextAlignment="Justify"
                                                Style="{StaticResource BodyStyle}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <ui:ButtonView
                            BodyText="{Binding RestartButtonText}"
                            TapCommand="{Binding Restart}" />

                    </StackLayout>

                </StackLayout>



            </StackLayout>
        </ScrollView>

    </StackLayout>
</ContentPage>