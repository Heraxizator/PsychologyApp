<?xml version="1.0" encoding="utf-8" ?>
<Shell  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="PsychologyApp.Presentation.AppShell"
        xmlns:views="clr-namespace:PsychologyApp.Presentation.Views"
        xmlns:tests="clr-namespace:PsychologyApp.Presentation.Views.Tests"
        xmlns:physics="clr-namespace:PsychologyApp.Presentation.Views.Physics"
        xmlns:cleans="clr-namespace:PsychologyApp.Presentation.Views.Clean"
        xmlns:forms="clr-namespace:PsychologyApp.Presentation.Views.Motivator"
        xmlns:mct="clr-namespace:CommunityToolkit.Maui.Behaviors;assembly=CommunityToolkit.Maui"
        xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
        Shell.TabBarForegroundColor="{StaticResource Primary}"
        Shell.TabBarTitleColor="{StaticResource Primary}"
        Shell.TabBarUnselectedColor="{StaticResource Gray400}"
        NavigationPage.HasNavigationBar="False"
        Shell.NavBarIsVisible="False"
        Shell.ForegroundColor="Black">

    <Shell.Behaviors>
        <mct:StatusBarBehavior StatusBarColor="White" StatusBarStyle="DarkContent"/>
    </Shell.Behaviors>

    <TabBar>

        <ShellContent 
                Title="Практик" 
                Icon="{mi:Material Icon=AutoAwesome}" />

        <ShellContent 
                Title="Детектор"
                Icon="{mi:Material Icon=Insights}" />

        <ShellContent 
                Title="Соматик"
                Icon="{mi:Material Icon=Favorite}" />
        
        <ShellContent 
                Title="Очиститель"
                Icon="{mi:Material Icon=Headphones}"/>
        
        <ShellContent
                Title="Мотиватор"
                Icon="{mi:Material Icon=Lightbulb}"/>
    

    </TabBar>
</Shell>