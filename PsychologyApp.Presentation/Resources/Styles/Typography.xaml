<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="TextPrimary">#DE000000</Color>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontFamily" Value="RobotoMedium" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="RobotoRegular" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="HorizontalTextAlignment" Value="Justify" />
    </Style>

    <Style x:Key="NavTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontFamily" Value="RobotoSemiBold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="NavBackIconStyle" TargetType="Label">
        <Setter Property="FontSize" Value="21" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="20,0,0,0" />
    </Style>

</ResourceDictionary>
