<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="CardFrameStyle" TargetType="Frame">
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Margin" Value="10" />
    </Style>

    <Style x:Key="BrandCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="10" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusShape}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#400085FF" Offset="0,0" Radius="10" Opacity="0.25" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border" BasedOn="{StaticResource BrandCardStyle}" />

    <Style x:Key="PrimaryActionBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusShape}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
        <Setter Property="Stroke" Value="{StaticResource Secondary}" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style x:Key="PrimaryActionLabelStyle" TargetType="Label">
        <Setter Property="Margin" Value="0,5,0,5" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="18" />
    </Style>

    <Style x:Key="CompactPrimaryBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="WidthRequest" Value="125" />
        <Setter Property="HeightRequest" Value="35" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CompactPrimaryLabelStyle" TargetType="Label">
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="RobotoMedium" />
    </Style>

    <Style x:Key="CompactSecondaryBorderStyle" TargetType="Border">
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusShape}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
        <Setter Property="Stroke" Value="{StaticResource Secondary}" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style x:Key="CompactSecondaryLabelStyle" TargetType="Label">
        <Setter Property="Margin" Value="0,3,0,3" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="14" />
    </Style>

</ResourceDictionary>
