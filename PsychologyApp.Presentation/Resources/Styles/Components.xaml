<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="CardFrameStyle" TargetType="Frame">
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource SurfaceDark}}" />
    </Style>

    <Shadow
        x:Key="BrandCardShadow"
        Brush="#400085FF"
        Offset="0,4"
        Radius="8"
        Opacity="0.2" />

    <!-- dvgups card: white, rounded-2xl, blue-tinted shadow -->
    <Style x:Key="BrandCardStyle" TargetType="Border">
        <Setter Property="Margin" Value="4,4,4,12" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusShape}" />
        <Setter Property="Shadow" Value="{StaticResource BrandCardShadow}" />
    </Style>

    <Style x:Key="ListCardItemStyle" TargetType="Border" BasedOn="{StaticResource BrandCardStyle}">
        <Setter Property="Margin" Value="4,4,4,12" />
    </Style>

    <!-- dvgups page panel: single white container on #FAFAFA -->
    <Style x:Key="BrandPanelStyle" TargetType="Border">
        <Setter Property="Margin" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusShape}" />
        <Setter Property="Shadow" Value="{StaticResource BrandCardShadow}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border" BasedOn="{StaticResource BrandCardStyle}" />

    <!-- FILLED primary button (dvgups Button FILLED + PRIMARY) -->
    <Style x:Key="PrimaryActionBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
    </Style>

    <Style x:Key="PrimaryActionLabelStyle" TargetType="Label">
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="{StaticResource MediumFontFamily}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <!-- OUTLINED secondary button (dvgups Button OUTLINED + SECONDARY) -->
    <Style x:Key="OutlinedActionBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{DynamicResource Primary}" />
        <Setter Property="StrokeThickness" Value="1.5" />
    </Style>

    <Style x:Key="OutlinedActionLabelStyle" TargetType="Label">
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="{StaticResource MediumFontFamily}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <Style x:Key="CompactPrimaryBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CompactPrimaryLabelStyle" TargetType="Label">
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="{StaticResource MediumFontFamily}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <Style x:Key="CompactOutlinedBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{DynamicResource Primary}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="CompactOutlinedLabelStyle" TargetType="Label">
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="{StaticResource MediumFontFamily}" />
        <Setter Property="LineBreakMode" Value="NoWrap" />
    </Style>

    <!-- Legacy aliases -->
    <Style x:Key="CompactSecondaryBorderStyle" TargetType="Border" BasedOn="{StaticResource CompactOutlinedBorderStyle}" />
    <Style x:Key="CompactSecondaryLabelStyle" TargetType="Label" BasedOn="{StaticResource CompactOutlinedLabelStyle}" />

    <!-- dvgups InputField shell -->
    <Style x:Key="InputBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusEntryShape}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource InputBackgroundLight}, Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource NeutralBorder}, Dark={StaticResource InputBorderDark}}" />
    </Style>

    <Style x:Key="InputTextStyle" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource BodyFontFamily}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource InputPlaceholderLight}, Dark={StaticResource InputPlaceholderDark}}" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style x:Key="MusicListRowStyle" TargetType="Border" BasedOn="{StaticResource ListCardItemStyle}">
        <Setter Property="Padding" Value="12,14" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
    </Style>

    <Style x:Key="ProfileTechniqueCardStyle" TargetType="Border" BasedOn="{StaticResource ListCardItemStyle}">
        <Setter Property="Padding" Value="12" />
        <Setter Property="WidthRequest" Value="228" />
        <Setter Property="MinimumHeightRequest" Value="112" />
        <Setter Property="Margin" Value="4,4,8,12" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
    </Style>

    <Style x:Key="ProfileAvatarBorderStyle" TargetType="Border">
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="{DynamicResource PrimaryTint}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 28" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style x:Key="TodayBannerStyle" TargetType="Border" BasedOn="{StaticResource ListCardItemStyle}">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="4,4,4,12" />
        <Setter Property="StrokeShape" Value="{DynamicResource UiCornerRadiusCompactShape}" />
    </Style>

    <Style x:Key="InputEditorStyle" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}" />
        <Setter Property="FontFamily" Value="{DynamicResource BodyFontFamily}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource InputPlaceholderLight}, Dark={StaticResource InputPlaceholderDark}}" />
    </Style>

</ResourceDictionary>
